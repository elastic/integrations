inputs:
    - data_stream:
        namespace: ep
      meta:
        package:
            name: crowdstrike
      name: test-default-crowdstrike
      streams:
        - auth.oauth2:
            client.id: test_client_id
            client.secret: ${SECRET_0}
            token_url: http://host.tld/oauth2/token
          config_version: 2
          data_stream:
            dataset: crowdstrike.identity_protection_timeline
          interval: 1h
          max_executions: 1000
          program: |-
            state.with(
              (
                state.?want_more.orValue(false) ?
                  state.start_time
                :
                  state.?cursor.last_timestamp.orValue(
                    (now - duration(state.initial_interval)).format(time_layout.RFC3339Nano)
                  )
              ).as(start_time,
                post_request(
                  state.url.trim_right("/") + "/identity-protection/combined/graphql/v1",
                  "application/json",
                  {
                    "query": state.query,
                    "variables": {
                      "startTime": start_time,
                      "first": int(state.batch_size),
                      ?"after": state.?cursor.end_cursor,
                    },
                  }.encode_json()
                ).do_request().as(resp, (resp.StatusCode == 200) ?
                  resp.Body.decode_json().as(body,
                    (size(body.?errors.orValue([])) > 0) ?
                      {
                        "events": {
                          "error": {
                            "code": "graphql",
                            "message": "POST " + state.url.trim_right("/") + "/identity-protection/combined/graphql/v1: " + body.errors.map(e, string(e.message)).join("; "),
                          },
                        },
                        "want_more": false,
                      }
                    : has(body.?data.timeline) ?
                      {
                        "events": body.data.timeline.?nodes.orValue([]).map(node,
                          {
                            "message": node.encode_json(),
                          }
                        ),
                        "start_time": start_time,
                        "cursor": {
                          ?"end_cursor": body.data.timeline.pageInfo.hasNextPage ?
                            optional.of(body.data.timeline.pageInfo.endCursor)
                          :
                            optional.none(),
                          ?"last_timestamp": (!body.data.timeline.pageInfo.hasNextPage && body.data.timeline.?nodes.orValue([]).size() > 0) ?
                            optional.of(body.data.timeline.nodes.last().timestamp)
                          :
                            state.?cursor.last_timestamp,
                        },
                        "want_more": body.data.timeline.pageInfo.hasNextPage,
                      }
                    :
                      {
                        "events": [],
                        "want_more": false,
                      }
                  )
                :
                  {
                    "events": {
                      "error": {
                        "code": string(resp.StatusCode),
                        "id": string(resp.Status),
                        "message": "POST " + state.url.trim_right("/") + "/identity-protection/combined/graphql/v1: " + (
                          (size(resp.Body) != 0) ?
                            string(resp.Body)
                          :
                            string(resp.Status) + " (" + string(resp.StatusCode) + ")"
                        ),
                      },
                    },
                    "want_more": false,
                  }
                )
              )
            )
          publisher_pipeline.disable_host: true
          redact:
            fields: null
          resource.ssl: null
          resource.timeout: 60s
          resource.tracer:
            enabled: true
            filename: ../../logs/cel/http-request-trace-*.ndjson
            maxbackups: 5
          resource.url: http://host.tld
          state:
            batch_size: 100
            initial_interval: 24h
            query: |-
                query GetTimelineEvents($startTime: DateTimeInput, $first: Int, $after: Cursor) {
                  timeline(
                    startTime: $startTime
                    first: $first
                    after: $after
                    sortOrder: ASCENDING
                    activityQuery: {
                      authenticationTypes: [DOMAIN_LOGIN, LDAP_AUTHENTICATION, KERBEROS_AUTHENTICATION]
                    }
                    types: [
                      SUCCESSFUL_AUTHENTICATION
                      FAILED_AUTHENTICATION
                      SERVICE_ACCESS
                      LDAP_SEARCH
                      ACCOUNT_CREATED
                      PASSWORD_CHANGE
                      ACCOUNT_ENABLED
                      ACCOUNT_DISABLED
                      ACCOUNT_LOCKED
                      PRIVILEGE_ESCALATION
                    ]
                  ) {
                    pageInfo {
                      hasNextPage
                      endCursor
                    }
                    nodes {
                      eventId
                      eventType
                      eventSeverity
                      eventLabel
                      timestamp
                      startTime
                      endTime
                      ... on TimelineUserOnEndpointActivityEvent {
                        userDisplayName
                        userEntity { primaryDisplayName emailAddresses }
                        endpointDisplayName
                        endpointEntity { primaryDisplayName }
                        targetEndpointEntity { primaryDisplayName }
                        ipAddress
                        hostName
                        activeDirectorySiteName
                        networkTag
                        networkType
                        operatingSystemInfo { name displayName family version }
                        protocolType
                        protocolVersion
                        geoLocation { country city }
                        ispClassification
                        ispDomain
                        ipAddressReputations
                        targetServiceDisplayName
                        targetServiceIdentifier
                        targetServiceType
                        targetServiceDescription
                        dataSourceVendorName
                      }
                      ... on TimelineAuthenticationEvent {
                        authenticationType
                        kerberosEncryptionTypes
                        ldapSecurityType
                        tlsVersion
                        smbDialect
                      }
                      ... on TimelineLdapSearchEvent {
                        ldapSearchFilterSample
                        ldapSearchAttributes
                        ldapSearchScope
                        ldapSearchSizeLimit
                        ldapSearchQuerySignatures
                      }
                      ... on TimelineEntityEvent {
                        entity {
                          primaryDisplayName
                          secondaryDisplayName
                          type
                          accounts {
                            ... on ActiveDirectoryAccountDescriptor {
                              samAccountName
                              servicePrincipalNames
                              objectSid
                            }
                          }
                        }
                      }
                    }
                  }
                }
          tags:
            - preserve_original_event
            - forwarded
            - crowdstrike-identity_protection_timeline
      type: cel
      use_output: default
output_permissions:
    default:
        _elastic_agent_checks:
            cluster:
                - monitor
        _elastic_agent_monitoring:
            indices: []
        uuid-for-permissions-on-related-indices:
            indices:
                - names:
                    - logs-crowdstrike.identity_protection_timeline-ep
                  privileges:
                    - auto_configure
                    - create_doc
secret_references:
    - {}
