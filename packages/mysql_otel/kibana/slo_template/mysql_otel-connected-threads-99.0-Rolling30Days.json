{
  "attributes": {
    "name": "[MySQL OTel] Connected threads 99.0% rolling 30 days",
    "description": "This SLO tracks connected thread count via mysql.threads (kind=connected), ensuring that 99.0% of 1-minute time intervals show fewer than 800 connected threads over a rolling period of 30 days. High connected threads relative to max_connections indicates connection pool pressure; keeping threads below a threshold maintains headroom for new connections.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"mysqlreceiver.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "last_value",
              "field": "mysql.threads",
              "filter": "attributes.kind: \"connected\""
            }
          ],
          "equation": "A",
          "comparator": "LT",
          "threshold": 800
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.99,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "mysql",
      "otel"
    ],
    "groupBy": "resource.attributes.mysql.instance.endpoint",
    "artifacts": {
      "dashboards": [
        { "id": "mysql_otel-233fa1a2-7c05-46b9-8ae6-112d42610e12" },
        { "id": "mysql_otel-71977e60-f126-4c18-8769-639e686585a3" },
        { "id": "mysql_otel-14f9bee0-b03e-4e6d-b386-c89d5e7589c8" },
        { "id": "mysql_otel-49452773-8358-4394-827e-d15d1e3f8467" }
      ]
    }
  },
  "id": "mysql_otel-connected-threads-99.0-Rolling30Days",
  "type": "slo_template"
}
