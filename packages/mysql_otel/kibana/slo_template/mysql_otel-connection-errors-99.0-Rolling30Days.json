{
  "attributes": {
    "name": "[MySQL OTel] Connection exhaustion errors 99.0% rolling 30 days",
    "description": "This SLO tracks max_connections errors via mysql.connection.errors, ensuring that 99.0% of 1-minute time intervals show fewer than 5 such errors per minute over a rolling period of 30 days. Max_connections errors indicate new clients are being refused; keeping this near zero maintains connection availability.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"mysqlreceiver.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "max",
              "field": "mysql.connection.errors",
              "filter": "attributes.error: \"max_connections\""
            },
            {
              "name": "B",
              "aggregation": "min",
              "field": "mysql.connection.errors",
              "filter": "attributes.error: \"max_connections\""
            }
          ],
          "equation": "A - B",
          "comparator": "LT",
          "threshold": 5
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.99,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "mysql",
      "otel"
    ],
    "groupBy": "resource.attributes.mysql.instance.endpoint",
    "artifacts": {
      "dashboards": [
        { "id": "mysql_otel-233fa1a2-7c05-46b9-8ae6-112d42610e12" },
        { "id": "mysql_otel-71977e60-f126-4c18-8769-639e686585a3" },
        { "id": "mysql_otel-14f9bee0-b03e-4e6d-b386-c89d5e7589c8" },
        { "id": "mysql_otel-49452773-8358-4394-827e-d15d1e3f8467" }
      ]
    }
  },
  "id": "mysql_otel-connection-errors-99.0-Rolling30Days",
  "type": "slo_template"
}
