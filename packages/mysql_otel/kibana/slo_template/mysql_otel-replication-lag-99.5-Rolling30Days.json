{
  "attributes": {
    "name": "[MySQL OTel] Replication lag 99.5% rolling 30 days",
    "description": "This SLO tracks replication lag via mysql.replica.time_behind_source, ensuring that 99.5% of 1-minute time intervals show the replica lag below 5 seconds over a rolling period of 30 days. Replication lag indicates stale reads for clients using read replicas; keeping lag low maintains data freshness.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"mysqlreceiver.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "last_value",
              "field": "mysql.replica.time_behind_source",
              "filter": ""
            }
          ],
          "equation": "A",
          "comparator": "LT",
          "threshold": 5
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "mysql",
      "otel"
    ],
    "groupBy": "resource.attributes.mysql.instance.endpoint",
    "artifacts": {
      "dashboards": [
        { "id": "mysql_otel-233fa1a2-7c05-46b9-8ae6-112d42610e12" },
        { "id": "mysql_otel-71977e60-f126-4c18-8769-639e686585a3" },
        { "id": "mysql_otel-14f9bee0-b03e-4e6d-b386-c89d5e7589c8" },
        { "id": "mysql_otel-49452773-8358-4394-827e-d15d1e3f8467" }
      ]
    }
  },
  "id": "mysql_otel-replication-lag-99.5-Rolling30Days",
  "type": "slo_template"
}
