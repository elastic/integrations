config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
{{#if max_executions}}
max_executions: {{max_executions}}
{{/if}}
resource.url: {{api_host}}
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}

program: |-
  {"startTime": state.?cursor.last_timestamp.orValue(timestamp(now() - duration(state.initial_interval)).format(time_layout.RFC3339))}.as(timeframe,
    request(
      "POST",
      state.url.trim_right("/") + "/graphql"
    ).with(
      {
        "Header": {
          "Content-Type": ["application/json"],
          "Accept": ["application/json"],
          "X-ApiKeys": ["key=" + state.key],
        },
        "Body": {
          "query": state.query,
          "variables": {
            "first": state.limit,
            "filter": {
              "op": "Or",
              "expressions": [
                {"field": "lastUpdate", "op": "GreaterEqual", "values": timeframe.startTime},
                {"field": "firstSeen", "op": "GreaterEqual", "values": timeframe.startTime},
              ]
            },
            "sort": [{"field": "lastUpdate", "direction": "AscNullFirst"}],
            ?"after": state.?cursor.end_cursor,
          },
        }.encode_json(),
      }
    ).do_request().as(resp,
      bytes(resp.Body).decode_json().as(body,
        body.data.assets.nodes.as(nodes,
          state.with(
            {
              "events": nodes.map(e,
                {
                  "message": e,
                  ?"event.original": state.?preserve_original_event.orValue(false) ? optional.of(e.encode_json()) : optional.none(),
                }
              ),
              "cursor": {
                "last_timestamp": (size(nodes) > 0) ?
                  nodes[size(nodes) - 1].lastUpdate 
                :
                  state.?cursor.last_timestamp.orValue(timeframe.startTime),
                ?"end_cursor": body.data.assets.pageInfo.hasNextPage ?
                  optional.of(body.data.assets.pageInfo.endCursor)
                :
                  optional.none(),
              },
              "want_more": body.data.assets.pageInfo.hasNextPage,
            }
          )
        )
      )
    )
  )

state:
  key: {{key}}
  limit: {{limit}}
  initial_interval: {{initial_interval}}
  preserve_original_event: {{preserve_original_event}}
  query: >-
    query getAssets($first: Int, $after: String, $filter: AssetExpressionsParams, $sort: [AssetSortParams!]) {
      assets(first: $first, after: $after, filter: $filter, sort: $sort) {
        nodes {
          id
          name
          firstSeen
          lastSeen
          lastHit
          lastSnapshot
          macs {
            nodes
          }
          ips {
            nodes
          }
          segments {
            nodes {
              id
            }
          }
          type
          superType
          category
          purdueLevel
          runStatus
          runStatusTime
          risk {
            totalRisk
          }
          criticality
          hidden
          lastUpdate
          directIps {
            nodes
          }
          directMacs {
            nodes
          }
        }
        pageInfo {
          hasNextPage
          endCursor
        }
      }
    }
