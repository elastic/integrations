config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
auth.oauth2:
  client.id: {{client_id}}
  client.secret: {{client_secret}}
  token_url: {{token_url}}
  scopes:
    - auditlog:events:list
{{#if user_id}}
  endpoint_params:
    sub:
      - "{{user_id}}"
{{/if}}
state:
  initial_interval: {{initial_interval}}
  batch_size: {{batch_size}}
{{#if performer_ids}}
  performer_ids: "{{performer_ids}}"
{{/if}}
{{#if event_types}}
  event_types: "{{event_types}}"
{{/if}}
  want_more: false
program: |
  state.with(
    state.?cursor.last_event_time.orValue(
      (now - duration(state.initial_interval)).format(time_layout.RFC3339)
    ).as(after_time,
      // Build headers; include pagination tokens if present in cursor
      {}.as(base_headers,
        state.?cursor.pit_id.orValue("") != "" ?
          base_headers.with({"Pit-Id": [state.cursor.pit_id]})
        :
          base_headers
      ).as(headers_with_pit,
        state.?cursor.search_after.orValue("") != "" ?
          headers_with_pit.with({"Search-After": [state.cursor.search_after]})
        :
          headers_with_pit
      ).as(headers,
        (state.url.trim_right("/") + "/events?" + {
          "paging":    ["true"],
          "after_time": [after_time],
          "size":      [string(int(state.batch_size))],
          ?"performer_ids": has(state.performer_ids) && state.performer_ids != "" ? optional.of([state.performer_ids]) : optional.none(),
          ?"event_types": has(state.event_types) && state.event_types != "" ? optional.of([state.event_types]) : optional.none(),
        }.format_query()).as(request_url,
          request("GET", request_url).with({
            "Header": headers,
          }).do_request().as(resp,
            resp.StatusCode == 200 ?
              resp.Body.decode_json().as(body, {
                "events": body.?results.orValue([]).map(e, {"message": e.encode_json()}),
                "cursor": {
                  "pit_id": body.?paging.pit_id.orValue(""),
                  "search_after": body.?paging.next_search_after.orValue(""),
                  "last_event_time": size(body.?results.orValue([])) > 0 ?
                    body.results[size(body.results) - 1].event_time
                  :
                    after_time,
                },
                "want_more": body.?paging.next_search_after.orValue(null) != null,
              })
            : resp.StatusCode == 429 ?
              // Rate limited — preserve state and retry on next interval
              {
                "events": [],
                "want_more": false,
              }
            : string(resp.Body).contains("Pit_Id") ?
              // Pit_Id expired — emit placeholder event to persist cursor update
              // (clearing pit_id/search_after while preserving last_event_time).
              // The placeholder is dropped by the drop_event processor below.
              {
                "events": [{"message": "pit_id_expired"}],
                "cursor": {
                  "pit_id": "",
                  "search_after": "",
                  "last_event_time": state.?cursor.last_event_time.orValue(after_time),
                },
                "want_more": false,
              }
            :
              // Other error — single-object form: cursor cleared, next run retries
              {"events": {"error": {
                "message": "GET /events: " + (
                  size(resp.Body) != 0 ?
                    string(resp.Body)
                  :
                    string(resp.Status) + " (" + string(resp.StatusCode) + ")"
                ),
              }}}
          )
        )
      )
    )
  )
drop_event.when.equals.message: "pit_id_expired"
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
