interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  initial_interval: {{initial_interval}}
  token_url: {{token_url}}
  client_id: {{client_id}}
  client_secret: {{client_secret}}
{{#if user_id}}
  user_id: "{{user_id}}"
{{/if}}
  batch_size: {{batch_size}}
{{#if performer_ids}}
  performer_ids: "{{performer_ids}}"
{{/if}}
{{#if event_types}}
  event_types: "{{event_types}}"
{{/if}}
  want_more: false
redact:
  fields:
    - client_secret
    - auth_token
{{!--
Greenhouse Audit Log API (Harvest V3 OAuth)

Endpoints:
  POST https://auth.greenhouse.io/token
    - HTTP Basic auth with client_id:client_secret
    - Body: grant_type=client_credentials[&sub=<user_id>]
    - Response: {access_token, expires_at (ISO-8601), token_type}
    - Note: expires_at is non-standard (RFC 6749 uses expires_in),
      so auth.oauth2 cannot manage token refresh — it is done here.

  GET https://auditlog.us.greenhouse.io/events
    - Query: paging=true, after_time, performer_ids, event_types
    - Headers: Authorization (Bearer), Size (page size 100-500),
      Pit-Id + Search-After (for page 2+)
    - Response: {paging: {pit_id, next_search_after}, results: [...]}
    - next_search_after is null on the last page.

State:
  auth_token — shallow-replaced object holding token and expires.
    Cleared to {} on 401 so the fields are absent, not sentinel-valued.

Cursor:
  last_event_time — stable during pagination; advances to session_max_time
    only when a full pagination session completes successfully.
  session_max_time — newest event_time captured on page 1 of each session
    (API returns newest-first). Preserved across pages, consumed on completion.
  pit_id, search_after — pagination state; cleared between poll intervals.
--}}
program: |-
  state.with(
    (
      !state.?auth_token.token.hasValue() || !state.?auth_token.expires.hasValue() ||
      timestamp(state.auth_token.expires) < now-duration("30s")
    ).as(need_token,
      need_token ?
        request("POST", state.token_url).with(
          {
            "Header": {
              "Content-Type": ["application/x-www-form-urlencoded"],
              "Authorization": ["Basic " + base64(state.client_id + ":" + state.client_secret)],
            },
            "Body": bytes(
              {
                "grant_type": ["client_credentials"],
                ?"sub": state.?user_id.optFlatMap(v,
                  (v != "") ? optional.of([v]) : optional.none()
                ),
              }.format_query()
            ),
          }
        ).do_request().as(resp,
          (resp.StatusCode == 200) ?
            resp.Body.decode_json().as(tok,
              {
                "auth_token": {
                  "token": tok.access_token,
                  "expires": tok.expires_at,
                },
              }
            )
          :
            {
              "events": {
                "error": {
                  "code": string(resp.StatusCode),
                  "id": string(resp.Status),
                  "message": "POST " + state.token_url + ": " + (
                    size(resp.Body) != 0 ?
                      string(resp.Body)
                    :
                      string(resp.Status) + ' (' + string(resp.StatusCode) + ')'
                  ),
                },
              },
            }
        )
      :
        {
          "auth_token": state.auth_token,
        }
    ).as(auth,
      has(auth.events) ?
        auth
      :
        (
          (state.?cursor.last_event_time.orValue("") != "") ?
            state.cursor.last_event_time
          :
            (now - duration(state.initial_interval)).format(time_layout.RFC3339)
        ).as(after_time,
          (
            // Query params must stay consistent across all pages in a session
            // (per API docs). after_time is stable because last_event_time is
            // frozen during pagination.
            state.url.trim_right("/") + "/events?" + {
              "paging": ["true"],
              "after_time": [after_time],
              ?"performer_ids": state.?performer_ids.optFlatMap(v,
                (v != "") ? optional.of([v]) : optional.none()
              ),
              ?"event_types": state.?event_types.optFlatMap(v,
                (v != "") ? optional.of([v]) : optional.none()
              ),
            }.format_query()
          ).as(url,
            {
              "Authorization": ["Bearer " + auth.auth_token.token],
              "Size": [string(int(state.batch_size))],
              ?"Pit-Id": state.?cursor.pit_id.optFlatMap(v,
                (v != "") ? optional.of([v]) : optional.none()
              ),
              ?"Search-After": state.?cursor.search_after.optFlatMap(v,
                (v != "") ? optional.of([v]) : optional.none()
              ),
            }.as(headers,
              request("GET", url).with({"Header": headers}).do_request().as(resp,
                (resp.StatusCode == 200) ?
                  resp.Body.decode_json().as(body,
                    (body.?paging.next_search_after.orValue(null) != null).as(has_more,
                      {
                        "auth_token": auth.auth_token,
                        "events": body.?results.orValue([]).map(e, {"message": e.encode_json()}),
                        "cursor": {
                          // Hold last_event_time stable during pagination so
                          // after_time stays consistent and Pit_Id expiry
                          // retries the full range (no data gap). Advance to
                          // session_max_time only on successful completion.
                          "last_event_time": has_more ?
                            after_time
                          :
                            (state.?cursor.session_max_time.orValue("") != "") ?
                              state.cursor.session_max_time
                            :
                              ((size(body.?results.orValue([])) > 0) ?
                                body.results[0].event_time
                              :
                                after_time),
                          // Capture newest event_time on page 1 (API returns
                          // newest-first). Preserve across subsequent pages.
                          "session_max_time": (state.?cursor.pit_id.orValue("") == "") && (size(body.?results.orValue([])) > 0) ?
                            body.results[0].event_time
                          :
                            state.?cursor.session_max_time.orValue(""),
                          "pit_id": has_more ? string(body.paging.pit_id) : "",
                          "search_after": has_more ? string(body.paging.next_search_after) : "",
                        },
                        "want_more": has_more,
                      }
                    )
                  )
                : (resp.StatusCode == 401) ?
                  {
                    "auth_token": {},
                    "events": [],
                    "want_more": false,
                  }
                : (resp.StatusCode == 429) ?
                  {
                    "events": [],
                    "want_more": false,
                  }
                : string(resp.Body).contains("Pit_Id") ?
                  // Pit_Id expired — clear pagination tokens and retry.
                  // Because last_event_time is held stable during pagination,
                  // after_time still equals the session start, so the next
                  // poll retries the full time range with no data gap.
                  {
                    "auth_token": auth.auth_token,
                    "events": [],
                    "cursor": {
                      "last_event_time": after_time,
                      "pit_id": "",
                      "search_after": "",
                    },
                    "want_more": false,
                  }
                :
                  {
                    "events": {
                      "error": {
                        "code": string(resp.StatusCode),
                        "id": string(resp.Status),
                        "message": "GET /events: " + ((size(resp.Body) != 0) ? string(resp.Body) : string(resp.Status)),
                      },
                    },
                  }
              )
            )
          )
        )
    )
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
