config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  want_more: false
  username: {{username}}
  password: {{password}}
  batch_size: {{batch_size}}
  initial_interval: "{{initial_interval}}"
  native_query: '{{native_query}}'
  sort: '{{sort}}'
  cursor_time_field: '{{cursor_time_field}}'
  cursor_tiebreaker_field: '{{cursor_tiebreaker_field}}'
redact:
  fields:
    - username
    - password
program: |
  (
    state.want_more && has(state.cursor) && has(state.cursor.poll_end)
    ?
      {
        "poll_end": state.cursor.poll_end,
        "page_start": int(state.cursor.page_start),
        "committed_ts": state.cursor.last_ts,
        "committed_num": state.cursor.last_num,
        "pending_ts": state.cursor.pending_ts,
        "pending_num": state.cursor.pending_num,
      }
    :
      {
        "poll_end": now.format(time_layout.RFC3339),
        "page_start": 0,
        "committed_ts": state.?cursor.last_ts.orValue(""),
        "committed_num": state.?cursor.last_num.orValue(""),
        "pending_ts": "",
        "pending_num": "",
      }
  ).as(req_ctx,
    (
      req_ctx.committed_ts == ""
      ?
        "(" + state.cursor_time_field + " < '" + req_ctx.poll_end + "') and (" + state.cursor_time_field + " >= '" + (now - duration(state.initial_interval)).format(time_layout.RFC3339) + "')"
      :
        "(" + state.cursor_time_field + " < '" + req_ctx.poll_end + "') and ((" + state.cursor_time_field + " > '" + req_ctx.committed_ts + "') or (" + state.cursor_time_field + " == '" + req_ctx.committed_ts + "' and " + state.cursor_tiebreaker_field + " > '" + req_ctx.committed_num + "'))"
    ).as(time_clause,
      ("(" + state.native_query + ") and " + time_clause).as(full_query,
        request(
          "GET",
          state.url.trim_right("/") + "?" + {
            "query": [full_query],
            "sort": [state.sort],
            "view": ["expand"],
            "count": [string(state.batch_size)],
            "start": [string(req_ctx.page_start)],
          }.format_query()
        ).with({
          "Header": {
            "Authorization": ["Basic " + base64(state.username + ":" + state.password)],
            "Accept": ["application/json"],
          },
        }).do_request().as(resp,
        (
          resp.StatusCode != 200
          ?
            {
              "events": [{
                "error": {
                  "code": string(resp.StatusCode),
                  "id": string(resp.Status),
                  "message": "GET " + state.url.trim_right("/") + ": " + (
                    size(resp.Body) != 0
                    ?
                      string(resp.Body)
                    :
                      string(resp.Status) + " (" + string(resp.StatusCode) + ")"
                  ),
                },
              }],
              "want_more": false,
              "username": state.username,
              "password": state.password,
              "batch_size": state.batch_size,
              "initial_interval": state.initial_interval,
              "native_query": state.native_query,
              "sort": state.sort,
              "cursor_time_field": state.cursor_time_field,
              "cursor_tiebreaker_field": state.cursor_tiebreaker_field,
              "cursor": state.?cursor.orValue({}),
            }
          :
            bytes(resp.Body).decode_json().as(body,
              (
                has(body.ReturnCode) && body.ReturnCode != null && body.ReturnCode != 0
                ?
                  {
                    "events": [{
                      "error": {
                        "code": string(resp.StatusCode),
                        "id": string(resp.Status),
                        "message": "Service Manager ReturnCode " + string(body.ReturnCode) + ": " + string(resp.Body),
                      },
                    }],
                    "want_more": false,
                    "username": state.username,
                    "password": state.password,
                    "batch_size": state.batch_size,
                    "initial_interval": state.initial_interval,
                    "native_query": state.native_query,
                    "sort": state.sort,
                    "cursor_time_field": state.cursor_time_field,
                    "cursor_tiebreaker_field": state.cursor_tiebreaker_field,
                    "cursor": state.?cursor.orValue({}),
                  }
                :
                  body.?entities.orValue(
                    type(body) == list
                    ?
                      body
                    :
                      []
                  ).as(entities,
                    size(entities).as(sz,
                      (
                        sz > 0
                        ?
                          (
                            has(entities[sz - 1].properties)
                            ?
                              entities[sz - 1].properties
                            :
                              entities[sz - 1]
                          )
                        :
                          {}
                      ).as(last_props,
                        (
                          sz > 0 && last_props[state.cursor_time_field] != null
                          ?
                            string(last_props[state.cursor_time_field])
                          :
                            ""
                        ).as(row_ts,
                          (
                            sz > 0 && last_props[state.cursor_tiebreaker_field] != null
                            ?
                              string(last_props[state.cursor_tiebreaker_field])
                            :
                              ""
                          ).as(row_num,
                            (
                              sz == 0 && req_ctx.page_start > 0
                              ?
                                {
                                  "wm": false,
                                  "lt": req_ctx.pending_ts != "" ? req_ctx.pending_ts : req_ctx.committed_ts,
                                  "ln": req_ctx.pending_num != "" ? req_ctx.pending_num : req_ctx.committed_num,
                                  "ps": "0",
                                  "pe": "",
                                  "pt": "",
                                  "pn": "",
                                }
                              :
                                (
                                  sz == 0 && req_ctx.page_start == 0
                                  ?
                                    {
                                      "wm": false,
                                      "lt": req_ctx.committed_ts,
                                      "ln": req_ctx.committed_num,
                                      "ps": "0",
                                      "pe": "",
                                      "pt": "",
                                      "pn": "",
                                    }
                                  :
                                    (
                                      sz >= int(state.batch_size)
                                      ?
                                        {
                                          "wm": true,
                                          "lt": req_ctx.committed_ts,
                                          "ln": req_ctx.committed_num,
                                          "ps": string(req_ctx.page_start + sz),
                                          "pe": req_ctx.poll_end,
                                          "pt": row_ts,
                                          "pn": row_num,
                                        }
                                      :
                                        {
                                          "wm": false,
                                          "lt": row_ts != "" ? row_ts : req_ctx.committed_ts,
                                          "ln": row_num != "" ? row_num : req_ctx.committed_num,
                                          "ps": "0",
                                          "pe": "",
                                          "pt": "",
                                          "pn": "",
                                        }
                                    )
                                )
                            ).as(cd,
                              {
                                "events": entities.map(ent, {
                                  "message": (
                                    has(ent.properties)
                                    ?
                                      ent.properties
                                    :
                                      ent
                                  ).encode_json(),
                                }),
                                "want_more": cd.wm,
                                "username": state.username,
                                "password": state.password,
                                "batch_size": state.batch_size,
                                "initial_interval": state.initial_interval,
                                "native_query": state.native_query,
                                "sort": state.sort,
                                "cursor_time_field": state.cursor_time_field,
                                "cursor_tiebreaker_field": state.cursor_tiebreaker_field,
                                "cursor": {
                                  "last_ts": cd.lt,
                                  "last_num": cd.ln,
                                  "page_start": cd.ps,
                                  "poll_end": cd.pe,
                                  "pending_ts": cd.pt,
                                  "pending_num": cd.pn,
                                },
                              }
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
        )
      )
    )
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
