paths:
{{#each paths as |path|}}
  - {{path}}
{{/each}}
exclude_files: [".gz$"]
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if ignore_older}}
ignore_older: {{ignore_older}}
{{/if}}
parsers:
  - include_message:
      patterns:
        - "krb5kdc\\["
