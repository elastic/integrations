{
    "id": "b60ddfdb-6963-59ad-8159-61b92ccfe68d",
    "type": "security-rule",
    "namespaces": [
        "default"
    ],
    "attributes": {
        "author": [
            "Ticura"
        ],
        "name": "[Ticura] Critical-severity Ticura indicator observed",
        "tags": [
            "Ticura",
            "Threat Intel",
            "Indicator Match"
        ],
        "description": "Variant of the standard Ticura indicator-match rules restricted to indicators with `event.severity >= 80` (Ticura risk category critical). High-priority alert track for tier-1 SOC workflows.",
        "rule_id": "b60ddfdb-6963-59ad-8159-61b92ccfe68d",
        "type": "threat_match",
        "language": "kuery",
        "query": "destination.ip:* or url.full:* or dns.question.name:* or file.hash.sha256:* or file.hash.md5:*",
        "threat_query": "event.module:\"ti_ticura\" and event.severity >= 80 and _tier:\"data_hot\" and not threat.indicator.expired:true",
        "threat_mapping": [
            {
                "entries": [
                    {
                        "field": "destination.ip",
                        "type": "mapping",
                        "value": "threat.indicator.ip"
                    }
                ]
            },
            {
                "entries": [
                    {
                        "field": "url.full",
                        "type": "mapping",
                        "value": "threat.indicator.url.full"
                    }
                ]
            },
            {
                "entries": [
                    {
                        "field": "dns.question.name",
                        "type": "mapping",
                        "value": "threat.indicator.url.domain"
                    }
                ]
            },
            {
                "entries": [
                    {
                        "field": "file.hash.sha256",
                        "type": "mapping",
                        "value": "threat.indicator.file.hash.sha256"
                    }
                ]
            },
            {
                "entries": [
                    {
                        "field": "file.hash.md5",
                        "type": "mapping",
                        "value": "threat.indicator.file.hash.md5"
                    }
                ]
            }
        ],
        "threat_index": [
            "logs-ti_ticura.ecs-*"
        ],
        "threat_filters": [],
        "threat_indicator_path": "threat.indicator",
        "threat_language": "kuery",
        "index": [
            "logs-*",
            "filebeat-*",
            "auditbeat-*",
            "winlogbeat-*",
            "packetbeat-*"
        ],
        "severity": "critical",
        "risk_score": 95,
        "enabled": false,
        "from": "now-30m",
        "to": "now",
        "interval": "10m",
        "max_signals": 100,
        "false_positives": [
            "Legitimate traffic to a host or URL that was previously reported as malicious and has since been remediated. Validate with the source feed (Ticura) before responding."
        ],
        "references": [
            "https://www.ticura.io",
            "https://docs.elastic.co/en/integrations/ti_ticura"
        ],
        "threat": [
            {
                "framework": "MITRE ATT&CK",
                "tactic": {
                    "id": "TA0011",
                    "name": "Command and Control",
                    "reference": "https://attack.mitre.org/tactics/TA0011/"
                },
                "technique": [
                    {
                        "id": "T1071",
                        "name": "Application Layer Protocol",
                        "reference": "https://attack.mitre.org/techniques/T1071/"
                    }
                ]
            }
        ],
        "note": "**Tier-1 SOC priority.** Use the `[Ticura] Critical-risk indicators in EU` saved search (or your regional variant) to scope the investigation.",
        "actions": [],
        "throttle": null,
        "version": 1,
        "exceptions_list": [],
        "license": "Elastic License v2",
        "meta": {
            "from": "now-30m"
        }
    },
    "references": []
}
