{
    "id": "39a522f3-4875-5335-891b-2eda02d28fd0",
    "type": "security-rule",
    "namespaces": [
        "default"
    ],
    "migrationVersion": {
        "security-rule": "8.16.0"
    },
    "attributes": {
        "author": [
            "Ticura"
        ],
        "name": "[Ticura] DNS query to known malicious domain",
        "tags": [
            "Ticura",
            "Threat Intel",
            "Indicator Match"
        ],
        "description": "Fires when a DNS query is observed for a domain currently flagged by Ticura as malicious. Catches phishing, C2, and malware-delivery domains.",
        "rule_id": "39a522f3-4875-5335-891b-2eda02d28fd0",
        "type": "threat_match",
        "language": "kuery",
        "query": "dns.question.name:*",
        "threat_query": "event.module:\"ti_ticura\" and threat.indicator.url.domain:* and _tier:\"data_hot\" and not threat.indicator.expired:true",
        "threat_mapping": [
            {
                "entries": [
                    {
                        "field": "dns.question.name",
                        "type": "mapping",
                        "value": "threat.indicator.url.domain"
                    }
                ]
            }
        ],
        "threat_index": [
            "logs-ti_ticura.ecs-*"
        ],
        "threat_filters": [],
        "threat_indicator_path": "threat.indicator",
        "threat_language": "kuery",
        "index": [
            "logs-*",
            "filebeat-*",
            "auditbeat-*",
            "winlogbeat-*",
            "packetbeat-*"
        ],
        "severity": "high",
        "risk_score": 73,
        "enabled": false,
        "from": "now-30m",
        "to": "now",
        "interval": "10m",
        "max_signals": 100,
        "false_positives": [
            "Legitimate traffic to a host or URL that was previously reported as malicious and has since been remediated. Validate with the source feed (Ticura) before responding."
        ],
        "references": [
            "https://www.ticura.io",
            "https://docs.elastic.co/en/integrations/ti_ticura"
        ],
        "threat": [
            {
                "framework": "MITRE ATT&CK",
                "tactic": {
                    "id": "TA0011",
                    "name": "Command and Control",
                    "reference": "https://attack.mitre.org/tactics/TA0011/"
                },
                "technique": [
                    {
                        "id": "T1071.004",
                        "name": "DNS",
                        "reference": "https://attack.mitre.org/techniques/T1071/004/"
                    }
                ]
            }
        ],
        "note": "**Investigation:** Use the `[Ticura] Active phishing URLs` saved search to triage other related domain indicators.",
        "actions": [],
        "throttle": null,
        "version": 1,
        "exceptions_list": [],
        "license": "Elastic License v2",
        "meta": {
            "from": "now-30m"
        }
    },
    "references": []
}
