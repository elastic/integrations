{
    "id": "e3a22e22-4f06-597a-90f2-e759bdf3c338",
    "type": "security-rule",
    "namespaces": [
        "default"
    ],
    "attributes": {
        "author": [
            "Ticura"
        ],
        "name": "[Ticura] File hash matches known malicious indicator",
        "tags": [
            "Ticura",
            "Threat Intel",
            "Indicator Match"
        ],
        "description": "Fires when a file observed on a monitored endpoint has a SHA-256, SHA-1, or MD5 hash matching a Ticura indicator. Common signal for EDR/sandbox integrations.",
        "rule_id": "e3a22e22-4f06-597a-90f2-e759bdf3c338",
        "type": "threat_match",
        "language": "kuery",
        "query": "file.hash.sha256:* or file.hash.sha1:* or file.hash.md5:*",
        "threat_query": "event.module:\"ti_ticura\" and threat.indicator.type:\"file\" and _tier:\"data_hot\" and not threat.indicator.expired:true",
        "threat_mapping": [
            {
                "entries": [
                    {
                        "field": "file.hash.sha256",
                        "type": "mapping",
                        "value": "threat.indicator.file.hash.sha256"
                    }
                ]
            },
            {
                "entries": [
                    {
                        "field": "file.hash.sha1",
                        "type": "mapping",
                        "value": "threat.indicator.file.hash.sha1"
                    }
                ]
            },
            {
                "entries": [
                    {
                        "field": "file.hash.md5",
                        "type": "mapping",
                        "value": "threat.indicator.file.hash.md5"
                    }
                ]
            }
        ],
        "threat_index": [
            "logs-ti_ticura.ecs-*"
        ],
        "threat_filters": [],
        "threat_indicator_path": "threat.indicator",
        "threat_language": "kuery",
        "index": [
            "logs-*",
            "filebeat-*",
            "auditbeat-*",
            "winlogbeat-*",
            "packetbeat-*"
        ],
        "severity": "critical",
        "risk_score": 85,
        "enabled": false,
        "from": "now-30m",
        "to": "now",
        "interval": "10m",
        "max_signals": 100,
        "false_positives": [
            "Legitimate traffic to a host or URL that was previously reported as malicious and has since been remediated. Validate with the source feed (Ticura) before responding."
        ],
        "references": [
            "https://www.ticura.io",
            "https://docs.elastic.co/en/integrations/ti_ticura"
        ],
        "threat": [
            {
                "framework": "MITRE ATT&CK",
                "tactic": {
                    "id": "TA0002",
                    "name": "Execution",
                    "reference": "https://attack.mitre.org/tactics/TA0002/"
                },
                "technique": [
                    {
                        "id": "T1204",
                        "name": "User Execution",
                        "reference": "https://attack.mitre.org/techniques/T1204/"
                    }
                ]
            }
        ],
        "note": "**Investigation:** Look up the matched hash in `[Ticura] Active malware file hashes` for full Ticura context (malware family, MITRE software, etc.).",
        "actions": [],
        "throttle": null,
        "version": 1,
        "exceptions_list": [],
        "license": "Elastic License v2",
        "meta": {
            "from": "now-30m"
        }
    },
    "references": []
}
