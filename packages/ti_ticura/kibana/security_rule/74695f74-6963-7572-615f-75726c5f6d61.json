{
    "id": "74695f74-6963-7572-615f-75726c5f6d61",
    "type": "security-rule",
    "namespaces": [
        "default"
    ],
    "migrationVersion": {
        "security-rule": "8.16.0"
    },
    "attributes": {
        "author": [
            "Ticura"
        ],
        "name": "[Ticura] URL access matches known malicious URL",
        "tags": [
            "Ticura",
            "Threat Intel",
            "Indicator Match"
        ],
        "description": "Fires when web traffic in the environment matches a URL indicator currently flagged by Ticura (e.g., phishing kit, credential-harvest, malware delivery).",
        "rule_id": "74695f74-6963-7572-615f-75726c5f6d61",
        "type": "threat_match",
        "language": "kuery",
        "query": "url.full:*",
        "threat_query": "event.module:\"ti_ticura\" and threat.indicator.url.full:* and _tier:\"data_hot\" and not threat.indicator.expired:true",
        "threat_mapping": [
            {
                "entries": [
                    {
                        "field": "url.full",
                        "type": "mapping",
                        "value": "threat.indicator.url.full"
                    }
                ]
            }
        ],
        "threat_index": [
            "logs-ti_ticura.ecs-*"
        ],
        "threat_filters": [],
        "threat_indicator_path": "threat.indicator",
        "threat_language": "kuery",
        "index": [
            "logs-*",
            "filebeat-*",
            "auditbeat-*",
            "winlogbeat-*",
            "packetbeat-*"
        ],
        "severity": "high",
        "risk_score": 73,
        "enabled": false,
        "from": "now-30m",
        "to": "now",
        "interval": "10m",
        "max_signals": 100,
        "false_positives": [
            "Legitimate traffic to a host or URL that was previously reported as malicious and has since been remediated. Validate with the source feed (Ticura) before responding."
        ],
        "references": [
            "https://www.ticura.io",
            "https://docs.elastic.co/en/integrations/ti_ticura"
        ],
        "threat": [
            {
                "framework": "MITRE ATT&CK",
                "tactic": {
                    "id": "TA0001",
                    "name": "Initial Access",
                    "reference": "https://attack.mitre.org/tactics/TA0001/"
                },
                "technique": [
                    {
                        "id": "T1566.002",
                        "name": "Spearphishing Link",
                        "reference": "https://attack.mitre.org/techniques/T1566/002/"
                    }
                ]
            }
        ],
        "note": "**Investigation:** Triage with the `[Ticura] Active phishing URLs` saved search.",
        "actions": [],
        "throttle": null,
        "version": 1,
        "exceptions_list": [],
        "license": "Elastic License v2",
        "meta": {
            "from": "now-30m"
        },
        "risk_score_mapping": [
            {
                "field": "event.severity",
                "operator": "equals",
                "value": "",
                "risk_score": null
            }
        ],
        "severity_mapping": []
    },
    "references": []
}
