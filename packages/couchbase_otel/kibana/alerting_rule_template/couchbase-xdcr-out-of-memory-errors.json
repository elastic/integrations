{
  "id": "couchbase-xdcr-out-of-memory-errors",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[Couchbase] XDCR out-of-memory errors",
    "ruleTypeId": ".es-query",
    "tags": [
      "observability",
      "couchbase",
      "errors"
    ],
    "schedule": {
      "interval": "5m"
    },
    "alertDelay": {
      "active": 1
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM metrics-couchbase.xdcr-default\n| STATS peak_xdcr_oom = MAX(couchbase.xdcr.errors.out_of_memory)\n| WHERE peak_xdcr_oom > 0.0"
      },
      "size": 0,
      "threshold": [
        0
      ],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 10,
      "timeWindowUnit": "m",
      "groupBy": "all",
      "excludeHitsFromPreviousRun": false
    }
  }
}
