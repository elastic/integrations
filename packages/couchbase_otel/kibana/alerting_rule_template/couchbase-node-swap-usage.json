{
  "id": "couchbase-node-swap-usage",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[Couchbase] Node swap usage detected",
    "ruleTypeId": ".es-query",
    "tags": [
      "observability",
      "couchbase",
      "saturation"
    ],
    "schedule": {
      "interval": "5m"
    },
    "alertDelay": {
      "active": 2
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM logs-couchbase.node-default\n// Any swap used on a node is undesirable for Couchbase\n| STATS max_swap_used_bytes = MAX(couchbase.node.swap.used.bytes)\n  BY couchbase.node.hostname\n| WHERE max_swap_used_bytes > 0\n| SORT max_swap_used_bytes DESC\n| LIMIT 50"
      },
      "size": 0,
      "threshold": [
        0
      ],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 10,
      "timeWindowUnit": "m",
      "groupBy": "row",
      "termField": "couchbase.node.hostname",
      "termSize": 50,
      "excludeHitsFromPreviousRun": true
    }
  }
}
