{
  "id": "couchbase-node-high-cpu",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[Couchbase] Node CPU utilization high",
    "ruleTypeId": ".es-query",
    "tags": [
      "observability",
      "couchbase",
      "saturation"
    ],
    "schedule": {
      "interval": "5m"
    },
    "alertDelay": {
      "active": 3
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM logs-couchbase.node-default\n| STATS avg_cpu_pct = AVG(couchbase.node.cpu_utilization_rate.pct)\n  BY couchbase.node.hostname\n| WHERE avg_cpu_pct > 90.0\n| SORT avg_cpu_pct DESC\n| LIMIT 50"
      },
      "size": 0,
      "threshold": [
        0
      ],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 15,
      "timeWindowUnit": "m",
      "groupBy": "row",
      "termField": "couchbase.node.hostname",
      "termSize": 50,
      "excludeHitsFromPreviousRun": true
    }
  }
}
