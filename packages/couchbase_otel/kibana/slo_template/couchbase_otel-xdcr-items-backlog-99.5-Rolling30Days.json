{
  "attributes": {
    "name": "[Couchbase OTel] XDCR items backlog 99.5% rolling 30 days",
    "description": "Ensures 99.5% compliance over 30 rolling days that 95% of 1-minute windows show XDCR replication backlog (couchbase.xdcr.items.remaining) below 500 items per collecting host, so cross-datacenter replication keeps up and DR and geo-distributed read paths stay fresh.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"couchbase.xdcr\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "avg",
              "field": "couchbase.xdcr.items.remaining",
              "filter": ""
            }
          ],
          "equation": "A",
          "comparator": "LT",
          "threshold": 500
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "couchbase",
      "otel"
    ],
    "groupBy": [
      "host.name"
    ]
  },
  "id": "couchbase_otel-xdcr-items-backlog-99.5-Rolling30Days",
  "type": "slo_template",
  "artifacts": {
    "dashboards": [
      {
        "id": "couchbase_otel-replication-health"
      },
      {
        "id": "couchbase_otel-cluster-overview"
      }
    ]
  }
}
