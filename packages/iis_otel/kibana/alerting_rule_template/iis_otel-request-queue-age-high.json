{
  "id": "iis_otel-request-queue-age-high",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[IIS OTel] Request queue age elevated",
    "ruleTypeId": ".es-query",
    "tags": ["observability", "iis"],
    "schedule": {
      "interval": "5m"
    },
    "alertDelay": {
      "active": 2
    },
    "flapping": {
      "enabled": true,
      "lookBackWindow": 10,
      "statusChangeThreshold": 4
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM metrics-iisreceiver.otel-*\n| WHERE iis.request.queue.age.max IS NOT NULL\n| STATS max_age_ms = MAX(iis.request.queue.age.max) BY iis.application_pool, host.name\n| WHERE max_age_ms > 5000\n| SORT max_age_ms DESC\n| LIMIT 20"
      },
      "size": 0,
      "threshold": [0],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 5,
      "timeWindowUnit": "m",
      "groupBy": "row",
      "termField": "iis.application_pool",
      "termSize": 20,
      "excludeHitsFromPreviousRun": true
    }
  }
}
