resource.url: {{#if use_https}}https{{else}}http{{/if}}://{{host}}:{{port}}/rpc/get-ospf-overview-information@format=json
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: {{timeout}}
auth.basic.user: {{username}}
auth.basic.password: {{password}}
state:
  initial:
    base_url: {{#if use_https}}https{{else}}http{{/if}}://{{host}}:{{port}}/rpc
redact:
  fields:
    - resource.url
    - state.base_url
program: |
  ({{#if device_name}}
    "{{device_name}}"
  {{else}}
    has(state.cursor) && has(state.cursor.device_hostname) && state.cursor.device_hostname != "" ?
      state.cursor.device_hostname
    :
      try(get(state.base_url + "/get-system-information@format=json")).as(si_resp,
        !is_error(si_resp) && si_resp.StatusCode == 200 ?
          bytes(si_resp.Body).decode_json().as(si_body,
            "system-information" in si_body && size(si_body["system-information"]) > 0
            && "host-name" in si_body["system-information"][0]
            && size(si_body["system-information"][0]["host-name"]) > 0
            ? string(si_body["system-information"][0]["host-name"][0]["data"])
            : "{{host}}"
          )
        : "{{host}}"
      )
  {{/if}}
  ).as(device_name,
    get(state.url).as(resp,
      resp.StatusCode == 200 ?
        bytes(resp.Body).decode_json().as(raw_body,
          // Unwrap multi-routing-engine-results wrapper if present
          ("multi-routing-engine-results" in raw_body
            && size(raw_body["multi-routing-engine-results"]) > 0
            && "multi-routing-engine-item" in raw_body["multi-routing-engine-results"][0]
            && size(raw_body["multi-routing-engine-results"][0]["multi-routing-engine-item"]) > 0
            ? raw_body["multi-routing-engine-results"][0]["multi-routing-engine-item"][0]
            : raw_body
          ).as(body,
            "ospf-overview-information" in body && size(body["ospf-overview-information"]) > 0
            && "ospf-overview" in body["ospf-overview-information"][0]
            && size(body["ospf-overview-information"][0]["ospf-overview"]) > 0 ?
              body["ospf-overview-information"][0]["ospf-overview"][0].as(overview,
                "ospf-area-overview" in overview ?
                  {"events": overview["ospf-area-overview"].map(area, {
                    "message": {
                      "instance-name": "instance-name" in overview ? overview["instance-name"] : [],
                      "ospf-router-id": "ospf-router-id" in overview ? overview["ospf-router-id"] : [],
                      "area": area
                    }.encode_json(),
                    "_observer_name": device_name,
                    "_observer_type": "{{observer_type}}",
                    "juniper.junos.ospf.instance_name": "instance-name" in overview && size(overview["instance-name"]) > 0 ? string(overview["instance-name"][0]["data"]) : "unknown",
                    "juniper.junos.ospf.router_id": "ospf-router-id" in overview && size(overview["ospf-router-id"]) > 0 ? string(overview["ospf-router-id"][0]["data"]) : "unknown",
                    "juniper.junos.ospf.area.id": "ospf-area" in area && size(area["ospf-area"]) > 0 ? string(area["ospf-area"][0]["data"]) : "unknown",
                  }), "cursor": {"device_hostname": device_name}}
                : {"events": [], "cursor": {"device_hostname": device_name}}
              )
            : {"events": [], "cursor": {"device_hostname": device_name}}
          )
        )
      : {"events": [], "cursor": {"device_hostname": device_name}}
    )
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
