{
    "id": "websphere_otel-hung-threads-detected",
    "type": "alerting_rule_template",
    "managed": true,
    "attributes": {
        "name": "[WebSphere OTel] Hung threads detected",
        "ruleTypeId": ".es-query",
        "tags": [
            "observability",
            "websphere"
        ],
        "schedule": {
            "interval": "1m"
        },
        "alertDelay": {
            "active": 2
        },
        "flapping": {
            "lookBackWindow": 10,
            "statusChangeThreshold": 4
        },
        "params": {
            "searchType": "esqlQuery",
            "esqlQuery": {
                "esql": "TS metrics-websphere.otel-default\n| WHERE metrics.was_threadpool_concurrentHung_threads IS NOT NULL\n| STATS\n    hung_threads = MAX(LAST_OVER_TIME(metrics.was_threadpool_concurrentHung_threads))\n  BY host.name, attributes.pool\n// Any hung thread warrants investigation\n// Hung threads block capacity and may indicate deadlocks or slow backends\n| WHERE hung_threads > 0\n| SORT hung_threads DESC"
            },
            "size": 0,
            "threshold": [
                0
            ],
            "thresholdComparator": ">",
            "timeField": "@timestamp",
            "timeWindowSize": 5,
            "timeWindowUnit": "m",
            "groupBy": "row",
            "termField": "attributes.pool",
            "termSize": 10
        }
    }
}
