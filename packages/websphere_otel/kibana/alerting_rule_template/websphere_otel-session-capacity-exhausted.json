{
    "id": "websphere_otel-session-capacity-exhausted",
    "type": "alerting_rule_template",
    "managed": true,
    "attributes": {
        "name": "[WebSphere OTel] Session capacity exhausted",
        "ruleTypeId": ".es-query",
        "tags": [
            "observability",
            "websphere"
        ],
        "schedule": {
            "interval": "1m"
        },
        "alertDelay": {
            "active": 1
        },
        "flapping": {
            "lookBackWindow": 10,
            "statusChangeThreshold": 4
        },
        "params": {
            "searchType": "esqlQuery",
            "esqlQuery": {
                "esql": "TS metrics-websphere.otel-default\n| WHERE metrics.was_session_noRoomForNewSession_total IS NOT NULL\n| STATS\n    rejection_rate = SUM(RATE(metrics.was_session_noRoomForNewSession_total))\n  BY host.name\n// Any non-zero rate means new sessions are being rejected\n// and users are being turned away from the application\n| WHERE rejection_rate > 0\n| SORT rejection_rate DESC"
            },
            "size": 0,
            "threshold": [
                0
            ],
            "thresholdComparator": ">",
            "timeField": "@timestamp",
            "timeWindowSize": 5,
            "timeWindowUnit": "m",
            "groupBy": "row",
            "termField": "host.name",
            "termSize": 10
        }
    }
}
