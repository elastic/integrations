{
    "id": "oracle_weblogic_otel-server-restarts",
    "type": "alerting_rule_template",
    "managed": true,
    "attributes": {
        "name": "[Oracle WebLogic OTel] Server restarts detected",
        "ruleTypeId": ".es-query",
        "tags": [
            "observability",
            "oracle_weblogic"
        ],
        "schedule": {
            "interval": "1m"
        },
        "alertDelay": {
            "active": 1
        },
        "flapping": {
            "lookBackWindow": 10,
            "statusChangeThreshold": 4
        },
        "params": {
            "searchType": "esqlQuery",
            "esqlQuery": {
                "esql": "TS metrics-oracle_weblogic.otel-*\n| WHERE weblogic.server.restarts IS NOT NULL\n| STATS restart_count = SUM(INCREASE(weblogic.server.restarts))\n    BY attributes.server\n// Any restart in the time window warrants investigation\n// Multiple restarts may indicate a crash loop\n| WHERE restart_count > 0\n| SORT restart_count DESC"
            },
            "size": 0,
            "threshold": [
                0
            ],
            "thresholdComparator": ">",
            "timeField": "@timestamp",
            "timeWindowSize": 5,
            "timeWindowUnit": "m",
            "groupBy": "row",
            "termField": "attributes.server",
            "termSize": 10
        }
    }
}
