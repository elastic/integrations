{
  "attributes": {
    "name": "[SQL Server OTel] Buffer cache hit ratio 99.5% rolling 30 days",
    "description": "This SLO tracks SQL Server buffer cache hit ratio via OTel metrics, ensuring that 99.5% of 1-minute time intervals show hit ratio at or above 95% over a rolling period of 30 days. A sustained drop below 95% indicates memory pressure and increased disk I/O, degrading query performance for users.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"sqlserverreceiver.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "avg",
              "field": "sqlserver.page.buffer_cache.hit_ratio"
            }
          ],
          "equation": "A",
          "comparator": "GTE",
          "threshold": 95
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "sqlserver",
      "otel"
    ],
    "groupBy": [
      "resource.attributes.service.instance.id"
    ],
    "artifacts": {
      "dashboards": [
        {
          "id": "microsoft_sqlserver_otel-overview"
        },
        {
          "id": "microsoft_sqlserver_otel-memory-saturation"
        }
      ]
    }
  },
  "id": "microsoft_sqlserver_otel-buffer-cache-hit-ratio-99.5-Rolling30Days",
  "type": "slo_template"
}
