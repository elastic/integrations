receivers:
  otlp:
    protocols:
      http:
        endpoint: 0.0.0.0:4318
service:
  pipelines:
    logs:
      receivers: [otlp]
{{#if preserve_original_event}}
      processors: [attributes]
processors:
  attributes:
    actions:
      - key: elastic.preserve_original_event
        value: "true"
        action: insert
{{/if}}
