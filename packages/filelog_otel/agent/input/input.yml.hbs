receivers:
  filelog:
    include:
{{#each include}}
      - {{this}}
{{/each}}
{{#if exclude}}
    exclude:
{{#each exclude}}
      - {{this}}
{{/each}}
{{/if}}
    start_at: {{start_at}}
{{#if exclude_older_than}}
    exclude_older_than: {{exclude_older_than}}
{{/if}}
    max_concurrent_files: {{max_concurrent_files}}
{{#if max_batches}}
    max_batches: {{max_batches}}
{{/if}}
    include_file_name: {{include_file_name}}
    include_file_path: {{include_file_path}}
    include_file_name_resolved: {{include_file_name_resolved}}
    include_file_path_resolved: {{include_file_path_resolved}}
    include_file_owner_name: {{include_file_owner_name}}
    include_file_owner_group_name: {{include_file_owner_group_name}}
    include_file_record_number: {{include_file_record_number}}
    include_file_record_offset: {{include_file_record_offset}}
    encoding: {{encoding}}
    preserve_leading_whitespaces: {{preserve_leading_whitespaces}}
    preserve_trailing_whitespaces: {{preserve_trailing_whitespaces}}
    fingerprint_size: {{fingerprint_size}}
    initial_buffer_size: {{initial_buffer_size}}
    max_log_size: {{max_log_size}}
    poll_interval: {{poll_interval}}
    force_flush_period: {{force_flush_period}}
{{#if multiline_line_start_pattern}}
    multiline:
      line_start_pattern: {{multiline_line_start_pattern}}
      omit_pattern: {{multiline_omit_pattern}}
{{else}}
{{#if multiline_line_end_pattern}}
    multiline:
      line_end_pattern: {{multiline_line_end_pattern}}
      omit_pattern: {{multiline_omit_pattern}}
{{/if}}
{{/if}}

service:
  pipelines:
    logs:
      receivers: [filelog]
