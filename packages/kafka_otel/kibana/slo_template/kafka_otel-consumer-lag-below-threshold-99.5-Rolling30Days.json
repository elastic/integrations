{
  "attributes": {
    "name": "[Kafka OTel] Consumer lag below threshold 99.5% rolling 30 days",
    "description": "This SLO tracks consumer group lag via kafkametricsreceiver OTel metrics, ensuring that 99.5% of 1-minute time intervals have maximum aggregate consumer lag (lag_sum) below 50000 messages per consumer-group-topic across the cluster over a rolling 30-day period. Sustained lag growth indicates consumers falling behind producers and increases end-to-end processing delay.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"kafkametricsreceiver.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "max",
              "field": "kafka.consumer_group.lag_sum",
              "filter": "kafka.consumer_group.lag_sum: *"
            }
          ],
          "equation": "A",
          "comparator": "LT",
          "threshold": 50000
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "kafka",
      "otel"
    ],
    "artifacts": {
      "dashboards": [
        {"id": "kafka_otel-overview"},
        {"id": "kafka_otel-consumer-groups"}
      ]
    }
  },
  "id": "kafka_otel-consumer-lag-below-threshold-99.5-Rolling30Days",
  "type": "slo_template"
}
