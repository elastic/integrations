{
  "attributes": {
    "name": "[Kafka OTel] Replication health 99.5% rolling 30 days",
    "description": "This SLO tracks partition replication health via kafkametricsreceiver OTel metrics, ensuring that 99.5% of 1-minute time intervals have the ratio of in-sync replicas to total replicas at 100% across all partitions. Under-replicated partitions (replicas_in_sync < replicas) indicate broker failures, network issues, or overload and weaken Kafka durability guarantees.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"kafkametricsreceiver.otel\" AND kafka.partition.replicas: *",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "sum",
              "field": "kafka.partition.replicas_in_sync",
              "filter": ""
            },
            {
              "name": "B",
              "aggregation": "sum",
              "field": "kafka.partition.replicas",
              "filter": ""
            }
          ],
          "equation": "A/B",
          "comparator": "GTE",
          "threshold": 1
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "kafka",
      "otel"
    ],
    "artifacts": {
      "dashboards": [
        {"id": "kafka_otel-overview"},
        {"id": "kafka_otel-replication"}
      ]
    }
  },
  "id": "kafka_otel-replication-health-99.5-Rolling30Days",
  "type": "slo_template"
}
