interval: {{interval}}
{{#if enable_request_tracer}}
resource.tracer.filename: "../../logs/cel/http-request-trace-*.ndjson"
resource.tracer.maxbackups: 5
resource.tracer.maxsize: 5
{{/if}}
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if resource_timeout}}
resource.timeout: {{resource_timeout}}
{{/if}}
resource.url: {{url}}
auth.oauth2:
  client.id: {{client_id}}
  client.secret: {{client_secret}}
  provider: azure
  scopes:
{{#each token_scopes as |token_scope|}}
    - {{token_scope}}
{{/each}}
  endpoint_params: 
    grant_type: client_credentials
{{#if token_url}}
  token_url: {{token_url}}/{{azure_tenant_id}}/oauth2/v2.0/token
{{else if azure_tenant_id}}
  azure.tenant_id: {{azure_tenant_id}}
{{/if}}
state:
  period: {{period}}
  path: /reports/getTeamsUserActivityUserDetail
redact:
  fields: ~
program: |
    state.with(
      request("GET",
        state.url.trim_right("/") + state.path + "(period='" + state.period + "')"
      ).do_request().as(resp,
        // Response is 200 success containing CSV without any redirect.
        resp.StatusCode == 200
        ?
          bytes(resp.Body).mime("text/csv; header=present").as(data, {
            "events": data.map(e, {
              "message": e.encode_json(),
            }),
            "want_more": false,
          })
        :
          (
            // Response is 302 indicating a redirect.
            resp.StatusCode == 302
            ?
              (
                has(resp.Header) && has(resp.Header.Location) && size(resp.Header.Location) > 0
                ?
                  (resp.Header.Location[0].as(location, 
                    get(location).as(rdr_resp, 
                      rdr_resp.StatusCode == 200
                      ?
                        bytes(rdr_resp.Body).mime("text/csv; header=present").as(data, {
                          "events": data.map(e, {
                            "message": e.encode_json(),
                          }),
                          "want_more": false,
                        })
                      :
                        {
                          "events": {
                            "error": {
                              "code": string(rdr_resp.StatusCode),
                              "id": string(rdr_resp.Status),
                              "message": "GET " + state.path + ": " + (
                                size(resp.Body) != 0 ?
                                  string(resp.Body)
                                :
                                  string(resp.Status) + ' (' + string(resp.StatusCode) + ')'
                              ),
                            },
                          },
                          "want_more": false,
                        }
                    )
                  ))
                :
                  // Response indicates a redirect but without a Location header to redirect to.
                  {
                    "events": {
                      "error": {
                        "code": string(resp.StatusCode),
                        "id": string(resp.Status),
                        "message": "Location not available in redirected response",
                      },
                    },
                    "want_more": false,
                  }  
              )
            :
              {
                "events": {
                  "error": {
                    "code": string(resp.StatusCode),
                    "id": string(resp.Status),
                    "message": "GET " + state.path + ": " + (
                      size(resp.Body) != 0 ?
                        string(resp.Body)
                      :
                        string(resp.Status) + ' (' + string(resp.StatusCode) + ')'
                    ),
                  },
                },
                "want_more": false,
              }
          )
      )
    )
tags:
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
