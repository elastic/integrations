interval: {{interval}}
{{#if enable_request_tracer}}
resource.tracer.filename: "../../logs/cel/http-request-trace-*.ndjson"
resource.tracer.maxbackups: 5
resource.tracer.maxsize: 5
{{/if}}
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if resource_timeout}}
resource.timeout: {{resource_timeout}}
{{/if}}
resource.url: {{url}}
auth.oauth2:
  client.id: {{client_id}}
  client.secret: {{client_secret}}
  provider: azure
  scopes:
{{#each token_scopes as |token_scope|}}
    - {{token_scope}}
{{/each}}
  endpoint_params: 
    grant_type: client_credentials
{{#if token_url}}
  token_url: {{token_url}}/{{azure_tenant_id}}/oauth2/v2.0/token
{{else if azure_tenant_id}}
  azure.tenant_id: {{azure_tenant_id}}
{{/if}}
state:
  initial_interval: "{{initial_interval}}"
  sync_days: "{{sync_days}}"
  path: /reports/getTeamsUserActivityUserDetail
  want_more: false
redact:
  fields: ~
program: |
  state.with(
    (
      state.want_more
      ?
        // Ongoing request to fetch data until current day. Fetch the next date from cursor.
        string(state.?cursor.next_report_date.value())
      :
        // New request
        (
          has(state.?cursor.next_report_date)
          ?
            // New request but has existing state. Start fetching from min(sync_days, cursor.next_report_date) from the past to help with filling gaps in data.
            int((now - duration(string(int(state.sync_days) * 24) + "h"))).as(sync_time, 
              (int(string(state.?cursor.next_report_date.value()).parse_time("2006-01-02")) < sync_time) 
              ?
                string(state.?cursor.next_report_date.value())
              :
                (now - duration(string(int(state.sync_days) * 24) + "h")).format("2006-01-02")
            )
          :
            // New request during initial setup. Start fetching from `initial_interval` days in the past.
            (now - duration(string(int(state.initial_interval) * 24) + "h")).format("2006-01-02")
        )
    ).as(report_date,
      request("GET",
        state.url.trim_right("/") + state.path + "(date=" + report_date + ")"
      ).do_request().as(resp,
        // Response is 200 success containing CSV. Any redirects are handled within CEL input.
        resp.StatusCode == 200
        ?
          bytes(resp.Body).mime("text/csv; header=present").as(data, {
            "events": data.map(e, {
              "message": e.encode_json(),
            }),
            "cursor": {
              // Add 24h to existing report_date to prepare for next report date.
              ?"next_report_date": optional.of((report_date.parse_time("2006-01-02") + duration("24h")).format("2006-01-02")),
            },
            "want_more": ((report_date.parse_time("2006-01-02") + duration("24h")) < now),
          })
        :
          {
            "events": {
              "error": {
                "code": string(resp.StatusCode),
                "id": string(resp.Status),
                "message": "GET " + state.path + ": " + (
                  size(resp.Body) != 0 ?
                    string(resp.Body)
                  :
                    string(resp.Status) + ' (' + string(resp.StatusCode) + ')'
                ),
              },
            },
            "want_more": false,
          }
      )
    )
  )
tags:
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
