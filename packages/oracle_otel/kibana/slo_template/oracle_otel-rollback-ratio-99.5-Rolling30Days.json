{
  "attributes": {
    "name": "[Oracle OTel] Rollback-to-commit ratio 99.5% rolling 30 days",
    "description": "This SLO tracks the rollback-to-commit ratio (user_rollbacks / (user_commits + user_rollbacks)) of the Oracle Database instance via OTel metrics. High ratios indicate systematic transaction failures from application bugs, lock contention, or constraint violations. The SLO ensures 99.5% of 1-minute intervals maintain the ratio below 10% over a rolling 30-day period.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"oracledbreceiver.otel\"",
        "metric": {
          "metrics": [
            {"name": "A", "aggregation": "max", "field": "oracledb.user_rollbacks"},
            {"name": "B", "aggregation": "min", "field": "oracledb.user_rollbacks"},
            {"name": "C", "aggregation": "max", "field": "oracledb.user_commits"},
            {"name": "D", "aggregation": "min", "field": "oracledb.user_commits"}
          ],
          "equation": "(A-B)/((A-B)+(C-D))",
          "comparator": "LT",
          "threshold": 0.10
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": ["oracle", "otel"],
    "groupBy": ["oracledb.instance.name"],
    "artifacts": {
      "dashboards": [
        {"id": "oracle_otel-overview"},
        {"id": "oracle_otel-transaction-health"}
      ]
    }
  },
  "id": "oracle_otel-rollback-ratio-99.5-Rolling30Days",
  "type": "slo_template"
}
