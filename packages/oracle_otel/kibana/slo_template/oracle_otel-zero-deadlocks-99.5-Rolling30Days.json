{
  "attributes": {
    "name": "[Oracle OTel] Zero enqueue deadlocks 99.5% rolling 30 days",
    "description": "This SLO tracks enqueue deadlocks (table/row lock deadlocks between sessions) of the Oracle Database instance via OTel metrics. Each deadlock causes a transaction rollback (ORA-00060). The SLO ensures 99.5% of 1-minute intervals experience zero new deadlocks over a rolling 30-day period.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"oracledbreceiver.otel\"",
        "metric": {
          "metrics": [
            {"name": "A", "aggregation": "max", "field": "oracledb.enqueue_deadlocks"},
            {"name": "B", "aggregation": "min", "field": "oracledb.enqueue_deadlocks"}
          ],
          "equation": "A-B",
          "comparator": "LTE",
          "threshold": 0
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": ["oracle", "otel"],
    "groupBy": ["oracledb.instance.name"],
    "artifacts": {
      "dashboards": [
        {"id": "oracle_otel-overview"},
        {"id": "oracle_otel-transaction-health"}
      ]
    }
  },
  "id": "oracle_otel-zero-deadlocks-99.5-Rolling30Days",
  "type": "slo_template"
}
