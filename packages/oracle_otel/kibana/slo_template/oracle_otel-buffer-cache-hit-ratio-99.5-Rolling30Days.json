{
  "attributes": {
    "name": "[Oracle OTel] Buffer cache hit ratio 99.5% rolling 30 days",
    "description": "This SLO tracks the buffer cache hit ratio (1 - physical_reads/logical_reads) of the Oracle Database instance via OTel metrics. A low ratio indicates excessive disk I/O and degraded query performance. The SLO ensures 99.5% of 1-minute intervals maintain a hit ratio above 95% over a rolling 30-day period.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"oracledbreceiver.otel\"",
        "metric": {
          "metrics": [
            {"name": "A", "aggregation": "max", "field": "oracledb.physical_reads"},
            {"name": "B", "aggregation": "min", "field": "oracledb.physical_reads"},
            {"name": "C", "aggregation": "max", "field": "oracledb.logical_reads"},
            {"name": "D", "aggregation": "min", "field": "oracledb.logical_reads"}
          ],
          "equation": "(A-B)/(C-D)",
          "comparator": "LT",
          "threshold": 0.05
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": ["oracle", "otel"],
    "groupBy": ["oracledb.instance.name"],
    "artifacts": {
      "dashboards": [
        {"id": "oracle_otel-overview"},
        {"id": "oracle_otel-sql-execution"}
      ]
    }
  },
  "id": "oracle_otel-buffer-cache-hit-ratio-99.5-Rolling30Days",
  "type": "slo_template"
}
