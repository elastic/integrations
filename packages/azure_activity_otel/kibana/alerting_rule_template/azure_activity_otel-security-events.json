{
  "id": "azure_activity_otel-security-events",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[Azure Activity OTel] Security events",
    "ruleTypeId": ".es-query",
    "tags": ["observability", "azure", "activity-logs", "security"],
    "schedule": {
      "interval": "5m"
    },
    "alertDelay": {
      "active": 1
    },
    "flapping": {
      "lookBackWindow": 10,
      "statusChangeThreshold": 4
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM logs-azure.activity.otel-*\n// Restrict to Azure Activity Logs (Security category)\n| WHERE azure.category IS NOT NULL\n| WHERE azure.category == \"Security\"\n// Derive actor for grouping\n| EVAL actor = COALESCE(user.id, \"unknown\")\n| STATS event_count = COUNT(*) BY actor, azure.operation.name\n| SORT event_count DESC\n| LIMIT 20"
      },
      "size": 0,
      "threshold": [0],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 15,
      "timeWindowUnit": "m",
      "groupBy": "row",
      "termField": "actor",
      "termSize": 10,
      "excludeHitsFromPreviousRun": true
    }
  }
}
