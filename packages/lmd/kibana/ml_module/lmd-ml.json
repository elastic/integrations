                    "analysis_config": {
                        "bucket_span": "15m",
                        "detectors": [
                            {
                                "detector_description": "rare by file_directory partitionfield=\"host.name\"",
                                "function": "rare",
                                "by_field_name": "file_directory",
                                "partition_field_name": "host.name",
