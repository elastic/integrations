config_version: 2
interval: {{interval}}

resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}

{{!-- https://api.hackerone.com/getting-started/#rate-limits --}}
resource.rate_limit.limit: 5
resource.rate_limit.burst: 20

resource.headers:
  Accept: application/json

state:
  initial_interval: {{initial_interval}}
  page_size: {{page_size}}
{{#if program_handles}}
  program_handles:
{{#each program_handles as |h|}}
    - "{{h}}"
{{/each}}
{{/if}}
{{#if inbox_ids}}
  inbox_ids:
{{#each inbox_ids as |id|}}
    - "{{id}}"
{{/each}}
{{/if}}
{{#if state_filter}}
  state_filter:
{{#each state_filter as |s|}}
    - "{{s}}"
{{/each}}
{{/if}}
{{#if severity_filter}}
  severity_filter:
{{#each severity_filter as |sev|}}
    - "{{sev}}"
{{/each}}
{{/if}}
  api_token_identifier: "{{api_token_identifier}}"
  api_token_value: "{{api_token_value}}"

redact:
  fields:
    - api_token_identifier
    - api_token_value

program: |-
  // Reports collection: GET /v1/reports paginated by `links.next`, with a
  // strictly-greater-than `last_activity_at` cursor. The +1ms guard on the
  // cursor compensates for HackerOne's millisecond-granularity comparison.
  //
  // State scope:
  // cursor.last_activity_at   persisted across restarts (resumable bookmark)
  // state.next                intra-session pagination URL (lost on restart;
  // intentional, so a stale URL never resurrects)
  // state.cycle_max           intra-session running max across the cycle's
  // pages; promoted into cursor on the final page
  (size(state.?program_handles.orValue([])) == 0 && size(state.?inbox_ids.orValue([])) == 0) ?
    state.with(
      {
        "events": {
          "error": {
            "code": "configuration",
            "id": "missing_scope_filter",
            "message": "At least one program handle or inbox id is required.",
          },
        },
        "want_more": false,
      }
    )
  :
    (
      // We have no URL, but allow this to be handled by the GET request.
      (state.?next.orValue("") != "") ?
        state.?next.orValue("")
      :
        state.url.trim_right("/") + "/v1/reports?" + {
          "sort": ["reports.last_activity_at"],
          "page[size]": [string(int(state.page_size))],
          "filter[last_activity_at__gt]": [
            (
              state.?cursor.last_activity_at.optMap(t,
                timestamp(t) + duration("1ms")
              )
            ).orValue(
              now - duration(state.initial_interval)
            ).format("2006-01-02T15:04:05.000Z07:00"),
          ],
          ?"filter[program][]": state.?program_handles[0].hasValue() ?
            optional.of(state.program_handles)
          :
            optional.none(),
          ?"filter[inbox_ids][]": state.?inbox_ids[0].hasValue() ?
            optional.of(state.inbox_ids)
          :
            optional.none(),
          ?"filter[state][]": state.?state_filter[0].hasValue() ?
            optional.of(state.state_filter)
          :
            optional.none(),
          ?"filter[severity][]": state.?severity_filter[0].hasValue() ?
            optional.of(state.severity_filter)
          :
            optional.none(),
        }.format_query()
    ).as(reqUrl,
      state.with(
        request("GET", reqUrl).with(
          {
            "Header": {
              "Authorization": ["Basic " + bytes(state.api_token_identifier + ":" + state.api_token_value).base64()],
            },
          }
        ).do_request().as(resp,
          (resp.StatusCode == 200) ?
            resp.Body.decode_json().as(body,
              {
                // HackerOne returns `{"links": {"next": null}}` when there is no next page and
                // `{"links": {"next": "..."}}` otherwise. `body.?links.?next.orValue(null)`
                // also collapses key absence into null defensively, so a single `!= null`
                // check covers every observed shape.
                "nextResolved": ((body.?links.?next.orValue(null) != null) ? string(body.links.next) : "").as(linkNext,
                  // Relative paths (start with "/") are resolved against state.url; absolute URLs pass through.
                  linkNext.startsWith("/") ?
                    (state.url.trim_right("/") + linkNext)
                  :
                    linkNext
                ),
                // Max(last_activity_at) on this page only; cycle running max folded later.
                "pageMax": body.?data.orValue([]).map(r,
                  r.?attributes.?last_activity_at.hasValue() || r.?attributes.?created_at.hasValue(),
                  r.?attributes.?last_activity_at.orValue(r.?attributes.created_at.orValue(""))
                ).as(stamps,
                  (size(stamps) > 0) ? stamps.max() : ""
                ),
                "events": body.?data.orValue([]).map(item, {"message": item.encode_json()}),
              }.as(d,
                (
                  // newMax = max(running cycle_max, this page's max). Computed once and reused.
                  !has(d.pageMax) ?
                    state.?cycle_max.orValue("")
                  : (state.?cycle_max.orValue("") != "") ?
                    ((d.pageMax > state.?cycle_max.orValue("")) ? d.pageMax : state.?cycle_max.orValue(""))
                  :
                    d.pageMax
                ).as(newMax,
                  (d.nextResolved != "" && d.nextResolved != reqUrl) ?
                    // Pagination continues — keep next, accumulate cycle_max, do NOT touch cursor yet.
                    {
                      "events": d.events,
                      "want_more": true,
                      "next": d.nextResolved,
                      "cycle_max": newMax,
                    }
                  :
                    // Last page in this cycle — promote newMax into cursor, clear transient state.
                    {
                      "events": d.events,
                      "want_more": false,
                      "next": "",
                      "cycle_max": "",
                      "cursor": (newMax != "") ?
                        state.?cursor.orValue({}).with({"last_activity_at": newMax})
                      :
                        state.?cursor.orValue({}),
                    }
                )
              )
            )
          :
            // Permanent client errors (4xx other than 429) -- emit an indexable error event,
            // preserve the cursor so the next cycle does not refetch the same failing window,
            // and let the pipeline terminate processor route it to error.message.
            {
              "events": [
                {
                  "error": {
                    "code": string(resp.StatusCode),
                    "id": string(resp.Status),
                    "message": (resp.StatusCode == 401) ?
                      "GET /v1/reports: invalid API token (401)"
                    : (resp.StatusCode == 403) ?
                      "GET /v1/reports: access denied - check program handle or IP allowlist (403)"
                    :
                      "GET /v1/reports: " + (
                        (size(resp.Body) != 0) ?
                          string(resp.Body)
                        :
                          string(resp.Status) + " (" + string(resp.StatusCode) + ")"
                      ),
                  },
                },
              ],
              "want_more": false,
              "next": "",
              "cycle_max": "",
            }
        )
      )
    )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}

{{#if processors}}
processors:
{{processors}}
{{/if}}
