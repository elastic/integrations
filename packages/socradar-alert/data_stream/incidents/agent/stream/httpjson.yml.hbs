config_version: "2"

interval: {{interval}}

request.method: "GET"
request.url: {{api_url}}/api/company/{{company_id}}/incidents/v4

{{#if enable_request_tracer}}
request.tracer.filename: "../../logs/httpjson/http-request-trace-*.ndjson"
request.tracer.maxbackups: 5
{{/if}}

request.transforms:
  - set:
      target: header.Api-Key
      value: '{{api_key}}'

  - set:
      target: url.params.limit
      value: '{{limit}}'

  - set:
      target: url.params.include_total_records
      value: 'true'

  - set:
      target: url.params.show_page_in_response
      value: 'true'

  - set:
      target: url.params.page
      value: '1'
      
  - set:
      target: url.params.include_alarm_details
      value: 'true'

  - set:
      target: url.params.include_company_id
      value: 'true'

  - set:
      target: url.params.start_date
      value: '[[.cursor.last_requested_at]]'
      default: '[[ formatDate (now (parseDuration "-{{initial_lookback}}")) "2006-01-02T15:04:05.000000" ]]'

response.decode_as: application/json

response.pagination:
  - set:
      target: url.params.page
      value: '[[ if and (gt (toInt .last_response.body.data.total_pages) 0) (lt (toInt .last_response.body.data.current_page) (toInt .last_response.body.data.total_pages)) ]][[ add (toInt .last_response.body.data.current_page) 1 ]][[ end ]]'
      fail_on_template_error: false
      do_not_log_failure: true

response.split:
  target: body.data.alarms
  ignore_empty_value: true

cursor:
  last_requested_at:
    value: '[[ if ge (toInt .last_response.body.data.current_page) (toInt .last_response.body.data.total_pages) ]][[ formatDate (now) "2006-01-02T15:04:05.000000" ]][[ else ]][[ .cursor.last_requested_at ]][[ end ]]'
    ignore_empty_value: true
    default: '[[ formatDate (now (parseDuration "-{{initial_lookback}}")) "2006-01-02T15:04:05.000000" ]]'

processors:
  - decode_json_fields:
      fields: ["message"]
      target: "alarm"
      overwrite_keys: true