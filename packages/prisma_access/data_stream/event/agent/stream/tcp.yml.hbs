host: "{{listen_address}}:{{listen_port}}"
{{#if tcp_options}}
{{tcp_options}}
{{/if}}
{{#if ssl}}
ssl: {{ssl}}
{{/if}}
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
processors:
- copy_fields:
    fields:
      - from: message
        to: event.original
    fail_on_error: true
    ignore_missing: false
# The decode_cef processor treats '\=' as a CEF escape sequence inside
# values, which causes parse failures for URLs containing literal '\='
# (e.g. query parameters like '?gtm\=value'). Strip these before decoding.
- replace:
    when.contains.message: '\='
    fields:
      - field: "message"
        pattern: "\\\\="
        replacement: "="
    ignore_missing: false
    fail_on_error: true
- decode_cef:
    field: message
    ecs: false
- drop_fields:
    fields: ["message"]
    ignore_missing: false
{{#if processors}}
{{processors}}
{{/if}}
