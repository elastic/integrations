{
  "attributes": {
    "name": "[ActiveMQ OTel] Store utilization 99.5% rolling 30 days",
    "description": "This SLO tracks persistent store utilization via OTel metrics, ensuring that 99.5% of 1-minute time intervals show store utilization below 90% over a rolling period of 30 days. Store exhaustion can halt acceptance of new persistent messages.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"activemq.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "last_value",
              "field": "activemq.store.utilization"
            }
          ],
          "equation": "A",
          "comparator": "LT",
          "threshold": 0.9
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "activemq",
      "otel"
    ],
    "groupBy": [
      "resource.attributes.activemq.broker.name"
    ]
  },
  "id": "activemq_otel-store-utilization-99.5-Rolling30Days",
  "type": "slo_template",
  "artifacts": {
    "dashboards": [
      { "id": "activemq_otel-broker-health" },
      { "id": "activemq_otel-overview" }
    ]
  }
}
