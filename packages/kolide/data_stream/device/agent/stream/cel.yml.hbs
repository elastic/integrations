interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
resource.headers:
  Accept:
    - application/json
  X-Kolide-Api-Version: "2026-04-07"
state:
  api_key: {{api_key}}
  batch_size: {{batch_size}}
redact:
  fields:
    - api_key
program: |-
  // Paginated GET /devices inventory snapshot; each device is emitted as a JSON message.
  state.?cursor.next.orValue("").as(next_token,
    state.with(
      request(
        "GET",
        state.url.trim_right("/") + "/devices?" + (
          (next_token != "") ?
            {
              "per_page": [string(int(state.batch_size))],
              "cursor": [next_token],
            }
          :
            {
              "per_page": [string(int(state.batch_size))],
            }
        ).format_query()
      ).with(
        {
          "Header": {
            "Authorization": ["Bearer " + state.api_key],
          },
        }
      ).do_request().as(resp,
        (resp.StatusCode == 200) ?
          resp.Body.decode_json().as(body,
            body.?pagination.next_cursor.orValue("").as(next_cursor,
              {
                "events": body.?data.orValue([]).map(e, {"message": e.encode_json()}),
                "cursor": {
                  "next": next_cursor,
                },
                "want_more": next_cursor != "",
              }
            )
          )
        :
          {
            "events": {
              "error": {
                "code": string(resp.StatusCode),
                "id": string(resp.Status),
                "message": "GET /devices: " + (
                  (size(resp.Body) != 0) ?
                    string(resp.Body)
                  :
                    string(resp.Status) + " (" + string(resp.StatusCode) + ")"
                ),
              },
            },
            "want_more": false,
          }
      )
    )
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
