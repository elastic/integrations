config_version: 2
interval: {{interval}}
auth.oauth2:
  client.id: {{client_id}}
  client.secret: {{client_secret}}
  token_url: {{token_url}}

resource.url: https://{{hostname}}.my.rubrik.com/api/graphql
{{#if ssl}}
resource.ssl: 
  {{ssl}}
{{/if}}
{{#if resource_timeout}}
resource.timeout: {{resource_timeout}}
{{/if}}

{{#if enable_request_tracer}}
resource.tracer.filename: "../../logs/cel/http-request-trace-*.ndjson"
{{/if}}

tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}

state:
  index: 0
  queries:
    - |
        query UnmanagedObjectsQuery($first: Int, $after: String, $input: UnmanagedObjectsInput!) {
          unmanagedObjects(first: $first, after: $after, input: $input) {
            pageInfo {
              startCursor
              endCursor
              hasPreviousPage
              hasNextPage
            }
            nodes {
              archiveStorage
              localStorage
              snapshotCount
              unmanagedStatus
              cluster {
                id
                name
              }
              effectiveSlaDomain {
                id
                name
              }
            }
          }
        }


program: |-
  state.with(
    request("POST", state.url).with(
      {
        "Header": {
          "Content-Type": ["application/json"],
        },
        "Body": {
          "query": state.queries[state.index],
          "variables": {
              {{#if first}}
              "first": {{first}},
              {{/if}}
              "after": has(state.cursor) ? state.cursor.after : null,
              "input": {
                "clusterUuid": "{{cluster_uuid}}",
                "unmanagedStatuses": [{{#each unmanaged_statuses}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
                "objectTypes": [{{#each object_types}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}],
                "retentionSlaDomainIds": [{{#each retention_sla_domain_ids}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]
              }
            }
        }.encode_json(),
      }
    ).do_request().as(resp, (resp.StatusCode == 200) ?
      bytes(resp.Body).decode_json().as(body,
        {
          "events": body.data.unmanagedObjects.nodes.map(e,
            {
              "message": e.encode_json(),
            }
          ),
          "want_more": body.data.unmanagedObjects.pageInfo.hasNextPage || int(state.index) < (size(state.queries) - 1),
          "queries": state.queries,
          "index": body.data.unmanagedObjects.pageInfo.hasNextPage ? int(state.index) : (int(state.index) + 1) % size(state.queries),
          "cursor": {
            "after": body.data.unmanagedObjects.pageInfo.hasNextPage ? body.data.unmanagedObjects.pageInfo.endCursor : null
          }
        }
      )
    :
      {
        "events": {
          "error": {
            "code": string(resp.StatusCode),
            "id": string(resp.Status),
            "message": "POST:" +
            (
              (size(resp.Body) != 0) ?
                string(resp.Body)
              :
                string(resp.Status) + " (" + string(resp.StatusCode) + ")"
            ),
          },
        },
        "want_more": false,
      }
    )
  )