config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  admin_token: {{admin_token}}
  initial_interval: {{initial_interval}}
  batch_size: {{batch_size}}
redact:
  fields:
    - admin_token
program: |-
  (
    state.?want_more.orValue(false) ?
      state
    :
      state.with({
        "start_time": state.?cursor.last_timestamp.orValue(int(now - duration(state.initial_interval))),
        "end_time": int(now),
      })
  ).as(state, state.with(
    request(
      "GET",
      state.url.trim_right("/") + "/v1/organization/audit_logs?" +
        "limit=" + string(state.batch_size) +
        (has(state.next) && state.next != null && has(state.next.before_cursor) ? "&before=" + string(state.next.before_cursor) : "") +
        "&effective_at%5Bgte%5D=" + string(int(state.start_time)) + "&effective_at%5Blte%5D=" + string(int(state.end_time))
    ).with({
      "Header": {
        "Authorization": ["Bearer " + string(state.admin_token)]
      }
    }).do_request().as(resp, resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body, {
        "events": (
            has(body.data)
          ?
            body.data.map(e, {
              "message": e.encode_json(),
            })
          :
            []
        ),
        "cursor": {
          ?"last_timestamp": (has(body.data) && size(body.data) > 0) ?
            (has(state.?cursor.last_timestamp) ?
              optional.of(
                max([
                  state.cursor.last_timestamp,
                  body.data[0].effective_at
                ])
              )
            :
              optional.of(body.data[0].effective_at)
            )
          :
            state.?cursor.last_timestamp
        },
        "want_more": body.?has_more.orValue(false),
        "next": {
          ?"before_cursor": body.?has_more.orValue(false) ?
            optional.of(body.last_id)
          :
            optional.none(),
        },
      })
    :
      {
        "events": {
          "error": {
            "code": string(resp.StatusCode),
            "id": string(resp.Status),
            "message": "GET:" + state.url.trim_right("/") + "/v1/organization/audit_logs: " + (
              size(resp.Body) != 0 ?
                string(resp.Body)
              :
                string(resp.Status) + ' (' + string(resp.StatusCode) + ')'
            ),
          },
        },
        "want_more": false,
      }
    )
  ))
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
