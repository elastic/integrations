metricsets: ["usage"]

period: {{period}}

api_keys:
  - key: "{{api_key}}"

api_url: "{{api_url}}"

headers:
{{#each headers}}
  - "{{this}}"
{{/each}}

rate_limit:
  limit: {{rate_limit.limit}}
  burst: {{rate_limit.burst}}

timeout: {{timeout}}

collection:
  lookback_days: {{collection.lookback_days}}
  realtime: {{collection.realtime}}
