config_version: 2
interval: {{interval}}
{{#if enable_request_tracer}}
resource.tracer.filename: "../../logs/cel/http-request-trace-*.ndjson"
resource.tracer.maxbackups: 5
{{/if}}
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
{{#if ioc_expiration_duration}}
fields_under_root: true
fields:
  _conf:
    ioc_expiration_duration: "{{ioc_expiration_duration}}"
{{/if}}
resource.url: {{url}}
state:
  api_key: {{api_key}}
  url: {{url}}
  initial_interval: {{initial_interval}}
  collections:
    {{collections_config}}
  collection_index: 0
redact:
  fields:
    - api_key
program: |
  state.collections[state.collection_index].as(current_collection, {
    "cid": string(current_collection.id),
    "cname": string(current_collection.?name.orValue(string(current_collection.id))),
    "has_checkpoint": has(current_collection.last_processed_date) && current_collection.last_processed_date != "",
    "last_date": (
      has(current_collection.last_processed_date) && current_collection.last_processed_date != ""
      ? string(current_collection.last_processed_date)
      : ""
    ),
  }).as(cc,
    request("GET", state.url + "/api/threat/intelligence/feed_list/" + cc.cid + ".json?" + {
      "key": [state.api_key],
      "v": ["2"],
    }.format_query()).do_request().as(resp,
      int(resp.StatusCode) == 200 ?
        bytes(resp.Body).decode_json().as(body,
          body.filter(item,
            has(item.feed) && size(string(item.feed)) > 0 &&
            (
              !cc.has_checkpoint ? true :
              has(item.latest_seen_date) && size(string(item.latest_seen_date)) > 0
              ? string(item.latest_seen_date) > cc.last_date
              : true
            )
          ).map(item, {
            "message": item.encode_json(),
            "_collection_id": cc.cid,
            "_collection_name": cc.cname,
          }).as(filtered_events, {
            "events": filtered_events,
            "want_more": int(state.collection_index) + 1 < size(state.collections),
            "collection_index": int(state.collection_index) + 1 < size(state.collections)
              ? int(state.collection_index) + 1
              : 0,
            "collections": state.collections.map(c,
              string(c.id) == cc.cid
              ? {
                  "id": cc.cid,
                  "name": cc.cname,
                  "last_processed_date": now.format("2006-01-02 15:04:05"),
                }
              : {
                  "id": string(c.id),
                  "name": string(c.?name.orValue(string(c.id))),
                  "last_processed_date": has(c.last_processed_date) ? string(c.last_processed_date) : "",
                }
            ),
            "api_key": string(state.api_key),
            "url": string(state.url),
            "initial_interval": string(state.initial_interval),
          })
        )
      :
        {
          "events": {
            "error": {
              "code": string(resp.StatusCode),
              "id": string(resp.Status),
              "message": "GET:" + (
                size(bytes(resp.Body)) != 0 ?
                  string(resp.Body)
                :
                  string(resp.Status) + " (" + string(resp.StatusCode) + ")"
              ),
            },
          },
          "want_more": int(state.collection_index) + 1 < size(state.collections),
          "collection_index": int(state.collection_index) + 1 < size(state.collections)
            ? int(state.collection_index) + 1
            : 0,
          "collections": state.collections.map(c, {
            "id": string(c.id),
            "name": string(c.?name.orValue(string(c.id))),
            "last_processed_date": has(c.last_processed_date) ? string(c.last_processed_date) : "",
          }),
          "api_key": string(state.api_key),
          "url": string(state.url),
          "initial_interval": string(state.initial_interval),
        }
    )
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
