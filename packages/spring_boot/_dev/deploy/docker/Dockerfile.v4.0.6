FROM maven:3.9-eclipse-temurin-25
RUN mkdir -p /build && chmod -R 777 /build
WORKDIR /build
COPY ./spring_boot_v4.0.6/ /build/spring_boot/
WORKDIR /build/spring_boot
RUN mvn package -q -DskipTests
HEALTHCHECK --interval=5s --retries=10 CMD curl -f http://springboot:8090/actuator/health || exit 1
ENTRYPOINT ["java","-jar","/build/spring_boot/target/actuator-0.0.1-Release.jar"]
