{
  "id": "envoyproxy_otel-server-not-live",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[Envoy OTel] Server not live",
    "ruleTypeId": ".es-query",
    "tags": [
      "observability",
      "envoy",
      "proxy-health"
    ],
    "schedule": {
      "interval": "1m"
    },
    "alertDelay": {
      "active": 2
    },
    "flapping": {
      "lookBackWindow": 5,
      "statusChangeThreshold": 3
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM metrics-statsdreceiver-default\n| WHERE data_stream.dataset == \"statsdreceiver\"\n| WHERE envoy.server.live IS NOT NULL\n// Server live is 1 when healthy, 0 when not\n| STATS max_live = MAX(envoy.server.live)\n| WHERE max_live < 1"
      },
      "size": 0,
      "threshold": [0],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 5,
      "timeWindowUnit": "m"
    }
  }
}
