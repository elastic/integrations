inputs:
    - data_stream:
        namespace: ep
      meta:
        package:
            name: ti_anomali
      name: test-default-ti_anomali
      streams:
        - config_version: 2
          data_stream:
            dataset: ti_anomali.intelligence
          fields:
            _conf:
                ioc_duration_before_deletion: 90d
          fields_under_root: true
          interval: 5m
          program: "state.with(\n  request(\n    \"GET\",\n    state.url.trim_right(\"/\") + \"/api/v2/intelligence/?\" + {\n      \"order_by\": [\"update_id\"],\n      \"modified_ts__lt\": [(now - duration(state.delay)).format(time_layout.RFC3339)],\n      ?\"modified_ts__gt\": state.?cursor.last_update_id.orValue(null) == null ? optional.of([(now - duration(state.initial_interval)).format(time_layout.RFC3339)]) : optional.none(),\n      \"limit\": [string(state.page_size)],\n      ?\"update_id__gt\": state.?cursor.last_update_id.optMap(id, [string(int(id))]),\n      ?\"remote_api\": state.remote_api_true ? optional.of([\"true\"]) : optional.none(), // never set remote_api=false, only true or absent\n      ?\"q\": state.?query.orValue(\"\") != \"\" ? optional.of([state.query]) : optional.none(),\n    }.format_query()\n  ).with(\n    {\n      \"Header\": {\n        \"Authorization\": [\"apikey \" + state.username + \":\" + state.api_key],\n      },\n    }\n  ).do_request().as(resp,\n    (resp.StatusCode == 200) ?\n      resp.Body.decode_json().as(body,\n        {\n          \"events\": body.objects.map(obj,\n            {\n              \"json\": obj,\n              ?\"event\": state.?preserve_original_event.orValue(false) ?\n                optional.of({\"original\": obj.encode_json()})\n              :\n                optional.none(),\n            }\n          ),\n          \"want_more\": body.meta.next != null,\n          \"cursor\": (has(state.cursor) ? state.cursor : {}).with(\n            {\n              ?\"last_update_id\": (body.objects.size() > 0) ? optional.of(body.objects[body.objects.size() - 1].update_id) : optional.none(),\n            }\n          ),\n        }\n      )\n    :\n      {\n        \"events\": {\n          \"error\": {\n            \"code\": string(resp.StatusCode),\n            \"id\": string(resp.Status),\n            \"message\": \"GET \" + state.url.trim_right(\"/\") + \"/api/v2/intelligence/: \" + \n            (\n              (size(resp.Body) != 0) ?\n                string(resp.Body)\n              :\n                string(resp.Status) + \" (\" + string(resp.StatusCode) + \")\"\n            ),\n          },\n        },\n        \"want_more\": false,\n      }\n  )\n)"
          publisher_pipeline.disable_host: true
          redact:
            fields:
                - api_key
          resource.ssl: null
          resource.timeout: 30s
          resource.tracer:
            enabled: null
            filename: ../../logs/cel/http-request-trace-*.ndjson
            maxbackups: 5
          resource.url: https://api.threatstream.com
          state:
            api_key: ${SECRET_0}
            delay: 1m
            initial_interval: 2160h
            page_size: 1000
            preserve_original_event: false
            remote_api_true: false
            username: test_username
            want_more: false
          tags:
            - forwarded
            - anomali-intelligence
      type: cel
      use_output: default
output_permissions:
    default:
        _elastic_agent_checks:
            cluster:
                - monitor
        _elastic_agent_monitoring:
            indices: []
        uuid-for-permissions-on-related-indices:
            indices:
                - names:
                    - logs-ti_anomali.intelligence-ep
                  privileges:
                    - auto_configure
                    - create_doc
secret_references:
    - {}
