config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  api_key: {{api_key}}
  page_size: {{page_size}}
redact:
  fields:
    - api_key
    - access_token
    - refresh_token
max_executions: 50
program: |-
  state.url.trim_right("/").as(base,
    state.with(
      (
        (
          state.?cursor.access_token.orValue("") == "" || state.?cursor.refresh_token.orValue("") == "" ||
          state.?cursor.need_reauth.orValue(false)
        ) ?
          post_request(base + "/api/auth", "application/json", "{}").with(
            {
              "Header": {
                "X-Api-Key": [state.api_key],
                "Content-Type": ["application/json"],
              },
            }
          ).do_request().as(authResp,
            (authResp.StatusCode == 200) ?
              authResp.Body.decode_json().as(ao,
                {
                  "ok": true,
                  "access": string(ao.accessToken),
                  "refresh": string(ao.refreshToken),
                }
              )
            :
              {
                "ok": false,
                "err_code": string(authResp.StatusCode),
                "err_status": string(authResp.Status),
                "err_body": (size(authResp.Body) != 0) ? string(authResp.Body) : string(authResp.Status),
              }
          )
        :
          {
            "ok": true,
            "access": string(state.?cursor.access_token.orValue("")),
            "refresh": string(state.?cursor.refresh_token.orValue("")),
          }
      ).as(tok,
        tok.ok ?
          request(
            "GET",
            (has(state.?next_page.link) && string(state.next_page.link) != "") ?
              (
                string(state.next_page.link).startsWith("http") ?
                  string(state.next_page.link)
                :
                  base + string(state.next_page.link)
              )
            :
              base + "/api/audit-trail/auditRecords?" + {
                "pageSize": [string(int(state.page_size))],
                "sort": ["-timestamp"],
              }.format_query()
          ).with(
            {
              "Header": {
                "Authorization": ["Bearer " + tok.access],
                "Content-Type": ["application/json"],
              },
            }
          ).do_request().as(resp,
            (resp.StatusCode == 200) ?
              resp.Body.decode_json().as(body,
                {
                  "events": body.?data.orValue([]).map(e, {"message": e.encode_json()}),
                  "cursor": {
                    "access_token": tok.access,
                    "refresh_token": tok.refresh,
                    "need_reauth": false,
                  },
                  "next_page": {
                    ?"link": (
                      has(body.paging) && has(body.paging.nextLink) && body.paging.nextLink != null &&
                      string(body.paging.nextLink) != ""
                    ) ? optional.of(string(body.paging.nextLink)) : optional.none(),
                  },
                  "want_more": has(body.paging) && has(body.paging.nextLink) && body.paging.nextLink != null &&
                  string(body.paging.nextLink) != "",
                }
              )
            : (resp.StatusCode == 401 || resp.StatusCode == 419) ?
              post_request(
                base + "/api/refresh-token",
                "application/json",
                {"refreshToken": tok.refresh}.encode_json()
              ).with(
                {
                  "Header": {"Content-Type": ["application/json"]},
                }
              ).do_request().as(refResp,
                (refResp.StatusCode == 200) ?
                  refResp.Body.decode_json().as(ro,
                    {
                      "events": [{"message": "retry"}],
                      "cursor": {
                        "access_token": string(ro.accessToken),
                        "refresh_token": string(ro.refreshToken),
                        "need_reauth": false,
                      },
                      "want_more": true,
                    }
                  )
                :
                  {
                    "events": [{"message": "retry"}],
                    "cursor": {
                      "access_token": "",
                      "refresh_token": "",
                      "need_reauth": true,
                    },
                    "want_more": true,
                  }
              )
            : (resp.StatusCode == 429) ?
              {
                "events": {
                  "error": {
                    "code": string(resp.StatusCode),
                    "id": string(resp.Status),
                    "message": "GET " + base +
                      "/api/audit-trail/auditRecords: rate limited",
                  },
                },
                "want_more": false,
              }
            :
              {
                "events": {
                  "error": {
                    "code": string(resp.StatusCode),
                    "id": string(resp.Status),
                    "message": "GET " + base +
                      "/api/audit-trail/auditRecords: " + (
                        (size(resp.Body) != 0) ? string(resp.Body) : string(resp.Status)
                      ),
                  },
                },
                "want_more": false,
              }
          )
        :
          {
            "events": {
              "error": {
                "code": tok.err_code,
                "id": tok.err_status,
                "message": "POST " + base +
                  "/api/auth: " + tok.err_body,
              },
            },
            "want_more": false,
          }
      )
    )
  )

tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#if preserve_duplicate_custom_fields}}
  - preserve_duplicate_custom_fields
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
