{
    "id": "couchdb_otel-conflict-storm",
    "type": "alerting_rule_template",
    "managed": true,
    "attributes": {
        "name": "[CouchDB OTel] Conflict storm (elevated 409 responses)",
        "ruleTypeId": ".es-query",
        "tags": [
            "observability",
            "couchdb"
        ],
        "schedule": {
            "interval": "5m"
        },
        "alertDelay": {
            "active": 2
        },
        "flapping": {
            "enabled": true,
            "lookBackWindow": 6,
            "statusChangeThreshold": 3
        },
        "params": {
            "searchType": "esqlQuery",
            "esqlQuery": {
                "esql": "TS metrics-couchdbreceiver.otel-default\n// 409 = update conflicts — spikes indicate write contention on same documents\n| WHERE attributes.http.status_code == \"409\"\n| STATS conflict_rate = SUM(RATE(couchdb.httpd.responses))\n  BY couchdb.node.name\n// Tune threshold: 409/s may be normal under load; >10/s often signals contention\n| WHERE conflict_rate > 10.0\n| SORT conflict_rate DESC\n| LIMIT 20"
            },
            "size": 0,
            "threshold": [0],
            "thresholdComparator": ">",
            "timeField": "@timestamp",
            "timeWindowSize": 15,
            "timeWindowUnit": "m",
            "groupBy": "row",
            "termField": "couchdb.node.name",
            "termSize": 20,
            "excludeHitsFromPreviousRun": true
        }
    }
}
