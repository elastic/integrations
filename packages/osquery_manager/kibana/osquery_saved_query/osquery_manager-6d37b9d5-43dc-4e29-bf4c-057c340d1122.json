        "id": "ai_mcp_config_files_darwin_elastic",
        "interval": "86400",
        "platform": "darwin",
        "query": "SELECT\n    path,\n    size,\n    datetime(mtime, 'unixepoch') AS modified_time,\n    datetime(atime, 'unixepoch') AS accessed_time\nFROM file\nWHERE path LIKE '/Users/%/Library/Application Support/Claude/claude_desktop_config.json'\n    OR path LIKE '/Users/%/.claude.json'\n    OR path LIKE '/Users/%/.claude/settings.json'\n    OR path LIKE '/Users/%/.cursor/mcp.json'\n    OR path LIKE '/Users/%/.vscode/mcp.json'\n    OR path LIKE '/Users/%/.mcp.json';",
        "updated_at": "2026-04-09T00:00:00.000Z",
