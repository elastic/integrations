        "id": "ai_mcp_config_files_windows_elastic",
        "interval": "86400",
        "platform": "windows",
        "query": "SELECT\n    path,\n    size,\n    datetime(mtime, 'unixepoch') AS modified_time,\n    datetime(atime, 'unixepoch') AS accessed_time\nFROM file\nWHERE path LIKE 'C:\\Users\\%\\AppData\\Roaming\\Claude\\claude_desktop_config.json'\n    OR path LIKE 'C:\\Users\\%\\.claude.json'\n    OR path LIKE 'C:\\Users\\%\\.claude\\settings.json'\n    OR path LIKE 'C:\\Users\\%\\.cursor\\mcp.json'\n    OR path LIKE 'C:\\Users\\%\\.vscode\\mcp.json'\n    OR path LIKE 'C:\\Users\\%\\.mcp.json';",
