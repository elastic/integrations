    "attributes": {
        "created_at": "2026-04-09T00:00:00.000Z",
        "created_by": "elastic",
        "description": "Detect running Model Context Protocol (MCP) server processes on endpoints. Use for shadow AI triage — identifies processes launched via @modelcontextprotocol packages, mcp-server-* binaries, fastmcp, smithery, mcpx, and MCP proxy/gateway tools across all platforms.",
