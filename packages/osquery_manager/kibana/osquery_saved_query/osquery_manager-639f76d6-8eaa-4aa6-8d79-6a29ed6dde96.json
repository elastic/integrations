        "id": "ai_mcp_config_files_linux_elastic",
        "interval": "86400",
        "platform": "linux",
        "query": "SELECT\n    path,\n    size,\n    datetime(mtime, 'unixepoch') AS modified_time,\n    datetime(atime, 'unixepoch') AS accessed_time\nFROM file\nWHERE path LIKE '/home/%/.config/Claude/claude_desktop_config.json'\n    OR path LIKE '/home/%/.claude.json'\n    OR path LIKE '/home/%/.claude/settings.json'\n    OR path LIKE '/home/%/.cursor/mcp.json'\n    OR path LIKE '/home/%/.vscode/mcp.json'\n    OR path LIKE '/home/%/.mcp.json';",
