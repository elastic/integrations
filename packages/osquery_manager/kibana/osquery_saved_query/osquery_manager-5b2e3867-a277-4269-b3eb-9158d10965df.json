        "id": "amcache_application_forensics_windows_elastic",
        "interval": "3600",
        "platform": "windows",
        "timeout": 180,
        "query": "-- Amcache Application Forensics: Combined application and file inventory\n-- Source: elastic_amcache_applications_view (Amcache.hve registry hive)\n-- Forensic value: Application execution/installation evidence with SHA1 hashes\n-- NOTE: Execution must be corroborated with additional artifacts\n\nSELECT\n  *,\n  datetime(timestamp, 'unixepoch') AS record_time\nFROM elastic_amcache_applications_view\nWHERE name IS NOT NULL AND name != ''\nORDER BY timestamp DESC;",
