    },
    {
      "type": "vis",
      "grid": {
        "x": 24,
        "y": 20,
        "w": 24,
        "h": 12
      },
      "config": {
        "type": "heatmap",
        "title": "Per-core non-idle share",
        "filters": [],
        "legend": {
          "size": "m",
          "visibility": "visible"
        },
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.utilization` IS NOT NULL AND attributes.state == \"idle\"\n| STATS iu = MAX(AVG_OVER_TIME(`system.cpu.utilization`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend), attributes.cpu\n| EVAL nidle = 1.0 - iu\n| SORT time_bucket ASC"
        },
        "x": {
          "column": "time_bucket",
          "label": "Time",
          "format": {
            "type": "custom",
            "pattern": "0"
          }
        },
        "y": {
          "column": "attributes.cpu",
          "label": "Core",
          "format": {
            "type": "custom",
            "pattern": "0"
          }
        },
        "metric": {
          "column": "nidle",
          "label": "Non-idle",
          "format": {
            "type": "percent",
            "decimals": 0
          }
        },
        "styling": {
          "cells": {
            "labels": {
              "visible": true
            }
          }
        }
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 0,
        "y": 32,
        "w": 48,
        "h": 10
      },
      "config": {
        "type": "data_table",
        "title": "Utilization by state and core",
        "filters": [],
        "styling": {
          "density": {
            "mode": "expanded"
          }
        },
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.utilization` IS NOT NULL\n| STATS uavg = AVG(AVG_OVER_TIME(`system.cpu.utilization`)) BY st = attributes.state, core = attributes.cpu\n| SORT uavg DESC\n| LIMIT 30"
        },
        "metrics": [
          {
            "column": "uavg",
            "label": "Mean utilization",
            "format": {
              "type": "percent",
              "decimals": 0
            }
          }
        ],
        "rows": [
          {
            "column": "st",
            "label": "State",
            "format": {
              "type": "custom",
              "pattern": "0"
            },
            "collapse_by": "min"
          },
          {
            "column": "core",
            "label": "Core",
            "format": {
              "type": "custom",
              "pattern": "0"
            },
            "collapse_by": "min"
          }
        ]
      }
    }
  ]
}
