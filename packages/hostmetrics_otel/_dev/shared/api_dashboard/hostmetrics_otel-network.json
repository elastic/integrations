      "grid": {
        "x": 0,
        "y": 8,
        "w": 48,
        "h": 12
      },
      "config": {
        "type": "xy",
        "title": "Interface throughput by direction",
        "filters": [],
        "legend": {
          "placement": "inside",
          "position": "top_right"
        },
        "axis": {
          "x": {
            "scale": "temporal",
            "labels": {
              "orientation": "horizontal"
            },
            "grid": {
              "visible": true
            },
            "ticks": {
              "visible": true
            }
          },
          "y": {
            "domain": {
              "type": "fit"
            },
            "scale": "linear",
            "labels": {
              "orientation": "horizontal"
            },
            "grid": {
              "visible": true
            },
            "ticks": {
              "visible": true
            }
          }
        },
        "styling": {
          "overlays": {},
          "fitting": {
            "type": "none"
          },
          "points": {},
          "areas": {},
          "bars": {}
        },
        "layers": [
          {
            "type": "area",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.io` IS NOT NULL\n| STATS tput = SUM(RATE(`system.network.io`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend), attributes.direction\n| SORT time_bucket ASC"
            },
            "x": {
              "column": "time_bucket",
              "label": "Time"
            },
            "y": [
              {
                "column": "tput",
                "format": {
                  "type": "bytes"
                },
                "label": "Bytes per second"
              }
            ],
            "breakdown_by": {
              "column": "attributes.direction",
              "label": "Direction"
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 12
      },
      "config": {
        "type": "xy",
        "title": "Interface packets per second by direction",
        "filters": [],
        "legend": {
          "placement": "inside",
          "position": "top_right"
        },
        "axis": {
          "x": {
            "scale": "temporal",
            "labels": {
              "orientation": "horizontal"
            },
            "grid": {
              "visible": true
            },
            "ticks": {
              "visible": true
