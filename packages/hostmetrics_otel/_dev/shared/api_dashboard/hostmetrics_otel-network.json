        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.io` IS NOT NULL\n| STATS tsum = SUM(RATE(`system.network.io`)) BY iface = attributes.device\n| SORT tsum DESC\n| LIMIT 20"
        },
