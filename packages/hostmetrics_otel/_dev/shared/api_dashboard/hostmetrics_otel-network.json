          }
        },
        "styling": {
          "overlays": {},
          "fitting": {
            "type": "none"
          },
          "points": {},
          "areas": {},
          "bars": {}
        },
        "layers": [
          {
            "type": "line",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.packets` IS NOT NULL\n| EVAL dlab2 = CONCAT(TO_STRING(attributes.device), \":\", TO_STRING(attributes.direction))\n| STATS pcr2 = SUM(RATE(`system.network.packets`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend), dlab2\n| SORT time_bucket ASC"
            },
            "x": {
              "column": "time_bucket",
              "label": "Time"
            },
            "y": [
              {
                "column": "pcr2",
                "label": "Packets /s",
                "format": {
                  "type": "number",
                  "decimals": 0
                }
              }
            ],
            "breakdown_by": {
              "column": "dlab2",
              "label": "Device and direction"
            }
          }
        ]
      }
    },
