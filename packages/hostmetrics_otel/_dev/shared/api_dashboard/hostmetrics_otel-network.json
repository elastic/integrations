      },
      "config": {
        "type": "pie",
        "title": "Connections by state",
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.connections` IS NOT NULL\n| STATS cx = MAX(LAST_OVER_TIME(`system.network.connections`)) BY attributes.state\n| SORT cx DESC\n| LIMIT 12"
        },
        "metrics": [
          {
            "column": "cx",
            "label": "Connections",
            "format": {
              "type": "number"
            }
          }
        ],
        "group_by": [
          {
            "column": "attributes.state",
            "label": "State",
            "format": {
              "type": "custom",
              "pattern": "0"
            },
            "collapse_by": "sum"
          }
        ],
        "legend": {
          "size": "m",
          "visibility": "visible"
        },
        "styling": {
          "values": {},
          "donut_hole": "m"
        }
