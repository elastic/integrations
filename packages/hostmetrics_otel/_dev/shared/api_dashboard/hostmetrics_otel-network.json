        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "ndrop",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.dropped` IS NOT NULL\n| STATS drp = SUM(RATE(`system.network.dropped`))"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
