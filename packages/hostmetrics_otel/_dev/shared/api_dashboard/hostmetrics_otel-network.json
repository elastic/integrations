    {
      "type": "vis",
      "grid": {
        "x": 0,
        "y": 42,
        "w": 48,
        "h": 10
      },
      "config": {
        "type": "data_table",
        "title": "Top interfaces by total throughput",
        "filters": [],
        "styling": {
          "density": {
