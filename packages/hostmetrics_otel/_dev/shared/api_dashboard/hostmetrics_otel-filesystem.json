{
  "title": "[System Host OTel] Filesystem",
  "description": "Mountpoint capacity, used bytes, and inode headroom to prevent runaway growth.",
  "time_range": {
    "from": "now-15m",
    "to": "now"
  },
  "options": {
    "use_margins": true,
    "sync_cursor": true,
    "sync_tooltips": false,
    "sync_colors": false,
    "auto_apply_filters": true
  },
  "query": {
    "expression": "",
    "language": "kql"
  },
  "refresh_interval": {
    "pause": true,
    "value": 60000
  },
  "access_control": {},
  "filters": [
    {
      "type": "condition",
      "condition": {
        "field": "data_stream.dataset",
        "operator": "is",
        "value": "hostmetricsreceiver.otel"
      }
    }
  ],
  "pinned_panels": [
    {
      "type": "options_list_control",
      "width": "medium",
      "config": {
        "data_view_id": "metrics-*",
        "field_name": "resource.attributes.host.name",
        "title": "Host"
      }
    }
  ],
  "panels": [
    {
      "type": "markdown",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 16,
        "h": 8
      },
      "config": {
        "content": "## [System Host OTel] Filesystem\n\nPer-mountpoint space and inode foot-print from the host metrics stream to catch capacity and inode fatigue.\n- Used, free, and reserved space as bytes in stacked trends\n- Same breakdown for inode usage where reported\n- Tables ordered by the largest used bytes and inode use",
        "hide_title": true,
        "settings": {
          "open_links_in_new_tab": true
        }
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "m1",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.filesystem.usage` IS NOT NULL AND attributes.state == \"used\"\n| STATS uby = MAX(LAST_OVER_TIME(`system.filesystem.usage`)) BY m = attributes.mountpoint\n| STATS tused2 = SUM(uby)"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "tused2",
            "label": "Bytes used all mounts",
            "format": {
              "type": "bytes"
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "m2",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.filesystem.usage` IS NOT NULL AND attributes.state == \"free\"\n| STATS fby = MAX(LAST_OVER_TIME(`system.filesystem.usage`)) BY mf = attributes.mountpoint\n| STATS tfree2 = SUM(fby)"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "tfree2",
            "label": "Bytes free all mounts",
            "format": {
              "type": "bytes"
            }
          }
        ]
      }
    },
    {
      "type": "vis",
