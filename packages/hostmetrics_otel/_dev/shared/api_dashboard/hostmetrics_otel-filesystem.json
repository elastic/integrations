        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.filesystem.inodes.usage` IS NOT NULL AND attributes.state == \"used\"\n| STATS iu2 = MAX(LAST_OVER_TIME(`system.filesystem.inodes.usage`)) BY mi = attributes.mountpoint\n| STATS isum2 = SUM(iu2)"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "isum2",
            "label": "Inodes used all mounts",
            "format": {
              "type": "number",
              "compact": true
            }
          }
        ]
