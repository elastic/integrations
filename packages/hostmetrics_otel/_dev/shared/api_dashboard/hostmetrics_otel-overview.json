          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.errors` IS NOT NULL\n| STATS nerr = SUM(RATE(`system.network.errors`))"
        },
        "styling": {
          "icon": {
            "name": "compute"
