    {
      "type": "vis",
      "grid": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 12
      },
      "config": {
        "type": "heatmap",
        "title": "Non-idle share by host",
        "filters": [],
        "legend": {
          "size": "m",
          "visibility": "visible"
        },
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.utilization` IS NOT NULL AND attributes.state == \"idle\"\n| STATS idu = MAX(AVG_OVER_TIME(`system.cpu.utilization`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend), resource.attributes.host.name\n| EVAL busy = 1.0 - idu\n| SORT time_bucket ASC"
        },
        "x": {
          "column": "time_bucket",
          "label": "Time",
          "format": {
            "type": "custom",
            "pattern": "0"
          }
        },
        "y": {
          "column": "resource.attributes.host.name",
          "label": "Host",
          "format": {
            "type": "custom",
            "pattern": "0"
          }
        },
        "metric": {
          "column": "busy",
          "label": "Non-idle share",
          "format": {
            "type": "percent",
            "decimals": 0
          }
        },
        "styling": {
          "cells": {
            "labels": {
              "visible": true
            }
          }
        }
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 24,
        "y": 32,
        "w": 24,
        "h": 12
      },
      "config": {
        "type": "pie",
        "title": "TCP connection states",
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.connections` IS NOT NULL\n| STATS ccount = MAX(LAST_OVER_TIME(`system.network.connections`)) BY attributes.state\n| SORT ccount DESC\n| LIMIT 12"
        },
        "metrics": [
          {
            "column": "ccount",
            "label": "Connections",
            "format": {
              "type": "number"
            }
          }
        ],
        "group_by": [
          {
            "column": "attributes.state",
            "label": "State",
            "format": {
              "type": "custom",
              "pattern": "0"
            },
            "collapse_by": "sum"
          }
        ],
        "legend": {
          "size": "m",
          "visibility": "visible"
        },
        "styling": {
          "values": {},
          "donut_hole": "m"
        }
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 0,
        "y": 44,
        "w": 48,
        "h": 16
      },
      "config": {
        "type": "data_table",
        "title": "Hosts ranked by non-idle CPU",
        "filters": [],
        "styling": {
          "density": {
            "mode": "expanded"
          }
        },
        "data_source": {
          "type": "esql",
          "query": "FROM metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.utilization` IS NOT NULL AND attributes.state == \"idle\"\n| STATS idavg = AVG(`system.cpu.utilization`) BY h = resource.attributes.host.name\n| EVAL nidle = 1.0 - idavg\n| SORT nidle DESC\n| LIMIT 30"
        },
        "metrics": [
          {
            "column": "nidle",
            "label": "Non-idle share",
            "format": {
              "type": "percent",
              "decimals": 1
            }
          }
        ],
        "rows": [
          {
            "column": "h",
            "label": "Host",
            "format": {
              "type": "custom",
              "pattern": "0"
            },
            "collapse_by": "min"
          }
        ]
      }
    }
  ]
}
