        "y": 20,
        "w": 24,
        "h": 12
      },
      "config": {
        "type": "xy",
        "title": "Memory utilization by state",
        "filters": [],
        "legend": {
          "placement": "inside",
          "position": "top_right"
        },
        "axis": {
          "x": {
            "scale": "temporal",
            "labels": {
              "orientation": "horizontal"
            },
            "grid": {
              "visible": true
            },
            "ticks": {
