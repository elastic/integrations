{
  "title": "[System Host OTel] Overview",
  "description": "Fleet-level host health: load, memory, network, process risk, and per-host non-idle CPU.",
  "time_range": {
    "from": "now-15m",
    "to": "now"
  },
  "options": {
    "use_margins": true,
    "sync_cursor": true,
    "sync_tooltips": false,
    "sync_colors": false,
    "auto_apply_filters": true
  },
  "query": {
    "expression": "",
    "language": "kql"
  },
  "refresh_interval": {
    "pause": true,
    "value": 60000
  },
  "access_control": {},
  "filters": [
    {
      "type": "condition",
      "condition": {
        "field": "data_stream.dataset",
        "operator": "is",
        "value": "hostmetricsreceiver.otel"
      }
    }
  ],
  "pinned_panels": [
    {
      "type": "options_list_control",
      "width": "medium",
      "config": {
        "data_view_id": "metrics-*",
        "field_name": "resource.attributes.host.name",
        "title": "Host"
      }
    }
  ],
  "panels": [
    {
      "type": "markdown",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 16,
        "h": 8
      },
      "config": {
        "content": "## [System Host OTel] Overview\n\nThis dashboard is the fleet view for OpenTelemetry host metrics. It highlights the signals that most often drive incidents.\n- CPU non-idle share and all three load averages over time\n- Memory use ratio and network byte throughput with direction\n- Hosts versus non-idle share and TCP connection state mix\n- Network error and drop rates plus disk and process risk indicators",
        "hide_title": true,
        "settings": {
          "open_links_in_new_tab": true
        }
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "KPI Load 1m",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.load_average.1m` IS NOT NULL\n| STATS l1m = MAX(LAST_OVER_TIME(`system.cpu.load_average.1m`))"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "l1m",
            "label": "Load 1m",
            "format": {
              "type": "number",
              "decimals": 2
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "KPI CPUs",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.logical.count` IS NOT NULL\n| STATS ncpu = MAX(LAST_OVER_TIME(`system.cpu.logical.count`))"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "ncpu",
            "label": "Logical CPUs",
            "format": {
              "type": "number",
              "decimals": 0
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 32,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "KPI Mem used",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.memory.utilization` IS NOT NULL AND attributes.state == \"used\"\n| STATS memu = AVG(AVG_OVER_TIME(`system.memory.utilization`))"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "memu",
            "label": "Memory used",
            "format": {
              "type": "percent",
              "decimals": 1
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 40,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "KPI busy",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.utilization` IS NOT NULL AND attributes.state == \"idle\"\n| STATS idu = AVG(AVG_OVER_TIME(`system.cpu.utilization`))\n| EVAL busy = 1 - idu"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
            "type": "primary",
            "column": "busy",
            "label": "CPU non-idle",
            "format": {
              "type": "percent",
              "decimals": 1
            }
          }
        ]
      }
    },
    {
      "type": "vis",
      "grid": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "KPI net err",
        "hide_title": true,
        "filters": [],
