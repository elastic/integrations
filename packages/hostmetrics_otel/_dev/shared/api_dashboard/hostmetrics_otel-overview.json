        },
        "layers": [
          {
            "type": "area",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.memory.utilization` IS NOT NULL\n| STATS mup = MAX(AVG_OVER_TIME(`system.memory.utilization`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend), attributes.state\n| SORT time_bucket ASC"
