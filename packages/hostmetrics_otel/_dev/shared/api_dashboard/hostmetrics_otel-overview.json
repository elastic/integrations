        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.network.dropped` IS NOT NULL\n| STATS ndp = SUM(RATE(`system.network.dropped`))"
        },
        "styling": {
