    {
      "type": "vis",
      "grid": {
        "x": 0,
        "y": 8,
        "w": 48,
        "h": 12
      },
      "config": {
        "type": "xy",
        "title": "Load averages",
        "filters": [],
        "legend": {
          "placement": "inside",
          "position": "top_right"
        },
        "axis": {
          "x": {
            "scale": "temporal",
            "labels": {
              "orientation": "horizontal"
            },
            "grid": {
              "visible": true
            },
            "ticks": {
              "visible": true
            }
          },
          "y": {
            "domain": {
              "type": "fit"
            },
            "scale": "linear",
            "labels": {
              "orientation": "horizontal"
            },
            "grid": {
              "visible": true
            },
            "ticks": {
              "visible": true
            }
          }
        },
        "styling": {
          "overlays": {},
          "fitting": {
            "type": "none"
          },
          "points": {},
          "areas": {},
          "bars": {}
        },
        "layers": [
          {
            "type": "line",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.load_average.1m` IS NOT NULL\n| STATS l1m = MAX(LAST_OVER_TIME(`system.cpu.load_average.1m`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend)\n| SORT time_bucket ASC"
            },
            "x": {
              "column": "time_bucket",
              "label": "Time"
            },
            "y": [
              {
                "column": "l1m",
                "label": "Load 1m",
                "format": {
                  "type": "number",
                  "decimals": 2
                }
              }
            ]
          },
          {
            "type": "line",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.load_average.5m` IS NOT NULL\n| STATS l5m = MAX(LAST_OVER_TIME(`system.cpu.load_average.5m`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend)\n| SORT time_bucket ASC"
            },
            "x": {
              "column": "time_bucket",
              "label": "Time"
            },
            "y": [
              {
                "column": "l5m",
                "label": "Load 5m",
                "format": {
                  "type": "number",
                  "decimals": 2
                }
              }
            ]
          },
          {
            "type": "line",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.cpu.load_average.15m` IS NOT NULL\n| STATS l15m = MAX(LAST_OVER_TIME(`system.cpu.load_average.15m`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend)\n| SORT time_bucket ASC"
            },
            "x": {
              "column": "time_bucket",
              "label": "Time"
            },
            "y": [
              {
                "column": "l15m",
                "label": "Load 15m",
                "format": {
                  "type": "number",
