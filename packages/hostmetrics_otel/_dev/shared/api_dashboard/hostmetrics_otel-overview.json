    {
      "type": "vis",
      "grid": {
        "x": 40,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "config": {
        "type": "metric",
        "title": "KPI zombie",
        "hide_title": true,
        "filters": [],
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.processes.count` IS NOT NULL AND attributes.status == \"zombies\"\n| STATS zc = MAX(LAST_OVER_TIME(`system.processes.count`))"
        },
        "styling": {
          "icon": {
            "name": "compute"
          }
        },
        "metrics": [
          {
