            "type": "none"
          },
          "points": {},
          "areas": {},
          "bars": {}
        },
        "layers": [
          {
            "type": "line",
            "data_source": {
              "type": "esql",
              "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.disk.operations` IS NOT NULL\n| EVAL dlab = CONCAT(TO_STRING(attributes.device), \":\", TO_STRING(attributes.direction))\n| STATS iop2 = SUM(RATE(`system.disk.operations`)) BY time_bucket = BUCKET(@timestamp, 20, ?_tstart, ?_tend), dlab\n| SORT time_bucket ASC"
            },
            "x": {
              "column": "time_bucket",
              "label": "Time"
            },
            "y": [
              {
                "column": "iop2",
                "label": "Ops /s",
                "format": {
                  "type": "number",
                  "decimals": 0
                }
              }
            ],
            "breakdown_by": {
              "column": "dlab",
              "label": "Device and direction"
            }
          }
        ]
      }
    },
