        },
        "data_source": {
          "type": "esql",
          "query": "TS metrics-hostmetricsreceiver.otel-*\n| WHERE data_stream.dataset == \"hostmetricsreceiver.otel\"\n| WHERE `system.disk.pending_operations` IS NOT NULL\n| STATS pm = MAX(LAST_OVER_TIME(`system.disk.pending_operations`)) BY dev = attributes.device\n| SORT pm DESC"
