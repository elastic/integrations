{
  "id": "airflow_otel-heartbeat-failures",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[Airflow OTel] Scheduler job heartbeat failures",
    "ruleTypeId": ".es-query",
    "tags": [
      "observability",
      "airflow",
      "scheduler",
      "heartbeat"
    ],
    "schedule": {
      "interval": "5m"
    },
    "alertDelay": {
      "active": 1
    },
    "flapping": {
      "lookBackWindow": 10,
      "statusChangeThreshold": 4
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM metrics-airflow.otel-default*\n| WHERE data_stream.dataset == \"airflow.otel\"\n| WHERE airflow.job_heartbeat_failure IS NOT NULL\n// Counter: sum heartbeat failures in the window\n| STATS failure_count = SUM(airflow.job_heartbeat_failure)\n| WHERE failure_count > 0"
      },
      "size": 0,
      "threshold": [0],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 15,
      "timeWindowUnit": "m"
    }
  }
}
