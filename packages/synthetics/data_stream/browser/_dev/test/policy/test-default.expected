inputs:
    - data_stream:
        namespace: ep
      meta:
        package:
            name: synthetics
      name: test-default-synthetics
      streams:
        - __ui: null
          data_stream:
            dataset: browser
            elasticsearch:
                privileges:
                    indices:
                        - auto_configure
                        - create_doc
                        - read
          enabled: true
          max_attempts: 2
          name: null
          run_from.geo.name: Fleet managed
          run_from.id: fleet_managed
          schedule: '@every 3m'
          throttling: null
          timeout: null
          type: browser
      type: synthetics/browser
      use_output: default
output_permissions:
    default:
        _elastic_agent_checks:
            cluster:
                - monitor
        _elastic_agent_monitoring:
            indices: []
        uuid-for-permissions-on-related-indices:
            indices:
                - names:
                    - synthetics-browser-ep
                  privileges:
                    - auto_configure
                    - create_doc
                    - read
secret_references: []
