extensions:
  awscredentialsprovider:
    region: {{region}}
{{#if profile}}
    profile: {{profile}}
{{/if}}
{{#if access_key_id}}
    access_key_id: {{access_key_id}}
{{/if}}
{{#if secret_access_key}}
    secret_access_key: {{secret_access_key}}
{{/if}}
{{#if session_token}}
    session_token: {{session_token}}
{{/if}}
{{#if role_arn}}
    assume_role:
      arn: {{role_arn}}
{{#if external_id}}
      external_id: {{external_id}}
{{/if}}
{{/if}}

receivers:
  awscloudwatch:
    auth: awscredentialsprovider
    region: {{region}}
{{#if imds_endpoint}}
    imds_endpoint: {{imds_endpoint}}
{{/if}}
    metrics:
      discovery:
        filters:
          namespace: "{{namespace}}"
        limit: {{autodiscover_limit}}
        stats:
          - "{{autodiscover_aggregation}}"

processors:
  resourcedetection/system:
    detectors: ["system"]
    system:
      hostname_sources: ["os"]
      resource_attributes:
        host.name:
          enabled: true
        host.id:
          enabled: false
  resourcedetection/aws:
    detectors: ["ec2", "ecs"]
    timeout: 2s
    override: false

service:
  extensions: [awscredentialsprovider]
  pipelines:
    metrics:
      receivers: [awscloudwatch]
      processors:
        - resourcedetection/system
        - resourcedetection/aws
