receivers:
  awscloudwatch:
    region: {{region}}
{{#if profile}}
    profile: {{profile}}
{{/if}}
{{#if imds_endpoint}}
    imds_endpoint: {{imds_endpoint}}
{{/if}}
    metrics:
      discovery:
        filters:
          namespace: "{{namespace}}"

processors:
  resourcedetection/system:
    detectors: ["system"]
    system:
      hostname_sources: ["os"]
      resource_attributes:
        host.name:
          enabled: true
        host.id:
          enabled: false
  resourcedetection/aws:
    detectors: ["ec2", "ecs"]
    timeout: 2s
    override: false

service:
  pipelines:
    metrics:
      receivers: [awscloudwatch]
      processors:
        - resourcedetection/system
        - resourcedetection/aws
