{
  "attributes": {
    "name": "[HAProxy OTel] Request success rate 99.5% rolling 30 days",
    "description": "This SLO tracks the proportion of HTTP requests that do not result in 5xx server errors, ensuring 99.5% of 1-minute timeslices meet the target over a rolling 30-day period. It uses haproxy.requests.total broken down by status_code to compute good (1xx, 2xx, 3xx, 4xx, other) vs total requests.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"haproxyreceiver.otel\"",
        "metric": {
          "metrics": [
            {"name": "A", "aggregation": "max", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"1xx\""},
            {"name": "B", "aggregation": "min", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"1xx\""},
            {"name": "C", "aggregation": "max", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"2xx\""},
            {"name": "D", "aggregation": "min", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"2xx\""},
            {"name": "E", "aggregation": "max", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"3xx\""},
            {"name": "F", "aggregation": "min", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"3xx\""},
            {"name": "G", "aggregation": "max", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"4xx\""},
            {"name": "H", "aggregation": "min", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"4xx\""},
            {"name": "I", "aggregation": "max", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"5xx\""},
            {"name": "J", "aggregation": "min", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"5xx\""},
            {"name": "K", "aggregation": "max", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"other\""},
            {"name": "L", "aggregation": "min", "field": "haproxy.requests.total", "filter": "attributes.status_code: \"other\""}
          ],
          "equation": "((A-B)+(C-D)+(E-F)+(G-H)+(K-L))/((A-B)+(C-D)+(E-F)+(G-H)+(I-J)+(K-L))",
          "comparator": "GTE",
          "threshold": 0.995
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": ["haproxy", "otel"],
    "groupBy": ["resource.attributes.haproxy.addr"],
    "artifacts": {
      "dashboards": [
        {"id": "haproxy_otel-overview"},
        {"id": "haproxy_otel-frontend"},
        {"id": "haproxy_otel-backend"}
      ]
    }
  },
  "id": "haproxy_otel-request-success-rate-99.5-Rolling30Days",
  "type": "slo_template"
}
