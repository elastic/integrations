{
    "id": "memcached_otel-high-eviction-rate",
    "type": "alerting_rule_template",
    "managed": true,
    "attributes": {
        "name": "[Memcached OTel] High eviction rate",
        "ruleTypeId": ".es-query",
        "tags": [
            "observability",
            "memcached"
        ],
        "schedule": {
            "interval": "5m"
        },
        "alertDelay": {
            "active": 2
        },
        "flapping": {
            "enabled": true,
            "lookBackWindow": 6,
            "statusChangeThreshold": 3
        },
        "params": {
            "searchType": "esqlQuery",
            "esqlQuery": {
                "esql": "TS metrics-memcachedreceiver.otel-*\n| WHERE memcached.evictions IS NOT NULL\n// Eviction rate (evictions/sec) — rising evictions indicate memory pressure\n| STATS eviction_rate = SUM(RATE(memcached.evictions))\n  BY host.name, COALESCE(service.instance.id, host.name)\n// Alert when eviction rate exceeds 10/sec — tune for your workload\n| WHERE eviction_rate > 10.0\n| SORT eviction_rate DESC\n| LIMIT 20"
            },
            "size": 0,
            "threshold": [0],
            "thresholdComparator": ">",
            "timeField": "@timestamp",
            "timeWindowSize": 5,
            "timeWindowUnit": "m",
            "groupBy": "row",
            "termField": "host.name",
            "termSize": 10,
            "excludeHitsFromPreviousRun": true
        }
    }
}
