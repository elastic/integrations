{
  "id": "etcd_otel-target-down",
  "type": "alerting_rule_template",
  "managed": true,
  "attributes": {
    "name": "[etcd OTel] Scrape target down",
    "ruleTypeId": ".es-query",
    "tags": [
      "observability",
      "etcd",
      "availability"
    ],
    "schedule": {
      "interval": "1m"
    },
    "alertDelay": {
      "active": 2
    },
    "flapping": {
      "lookBackWindow": 6,
      "statusChangeThreshold": 3
    },
    "params": {
      "searchType": "esqlQuery",
      "esqlQuery": {
        "esql": "FROM metrics-etcd.otel-default*\n// Scrape health: up=0 when Prometheus/OTel collector cannot reach the etcd metrics endpoint\n| WHERE `up` IS NOT NULL\n  AND `up` == 0\n| STATS count = COUNT(*) BY resource.attributes.service.instance.id\n| SORT count DESC"
      },
      "size": 0,
      "threshold": [0],
      "thresholdComparator": ">",
      "timeField": "@timestamp",
      "timeWindowSize": 5,
      "timeWindowUnit": "m",
      "groupBy": "row",
      "termField": "resource.attributes.service.instance.id",
      "termSize": 20,
      "excludeHitsFromPreviousRun": false
    }
  }
}
