{
  "attributes": {
    "name": "[etcd OTel] Apply latency (non-slow) rate 99.5% rolling 30 days",
    "description": "This SLO tracks the proportion of Raft applies that complete within the expected duration via OTel metrics, ensuring that 99.5% of 1-minute time intervals show a non-slow apply rate ((applied - slow_apply) / applied) of at least 99.5% over a rolling period of 30 days. Slow applies indicate the backend or disk cannot keep up, causing increased write latency visible to all etcd clients including the Kubernetes API server.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"etcd.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "max",
              "field": "etcd_server_proposals_applied_total",
              "filter": ""
            },
            {
              "name": "B",
              "aggregation": "min",
              "field": "etcd_server_proposals_applied_total",
              "filter": ""
            },
            {
              "name": "C",
              "aggregation": "max",
              "field": "etcd_server_slow_apply_total",
              "filter": ""
            },
            {
              "name": "D",
              "aggregation": "min",
              "field": "etcd_server_slow_apply_total",
              "filter": ""
            }
          ],
          "equation": "((A-B)-(C-D))/(A-B)",
          "comparator": "GTE",
          "threshold": 0.995
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "etcd",
      "otel"
    ],
    "groupBy": "resource.attributes.service.instance.id"
  },
  "id": "etcd_otel-slow-apply-rate-99.5-Rolling30Days",
  "type": "slo_template",
  "artifacts": {
    "dashboards": [
      { "id": "etcd_otel-overview" },
      { "id": "etcd_otel-raft-consensus" }
    ]
  }
}
