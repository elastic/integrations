{{#if suppress_health_degradation}}suppress_health_degradation: {{suppress_health_degradation}}{{/if}}
interval: {{period}}
resource.url: '{{zabbix_url}}/api_jsonrpc.php'
resource.timeout: {{timeout}}
resource.ssl:
  verification_mode: '{{#if ssl_verification}}full{{else}}none{{/if}}'
{{#if ssl.certificate_authorities}}
  certificate_authorities:
{{#each ssl.certificate_authorities}}
  - {{this}}
{{/each}}
{{/if}}
state:
  api_token: '{{api_token}}'
redact:
  fields:
    - resource.url
    - state.api_token
program: |
  (
    request("POST", state.url).with({
      "Header": {
        "Content-Type": ["application/json-rpc"],
        "Authorization": ["Bearer " + state.api_token]
      },
      "Body": bytes({
        "jsonrpc": "2.0",
        "method": "problem.get",
        "params": {
          "output": "extend",
          "selectTags": "extend",
          "selectAcknowledges": "extend",
          "recent": true,
          "sortfield": "eventid",
          "sortorder": "ASC",
          "limit": 500
        },
        "id": 1
      }.encode_json())
    }).do_request().as(resp,
      resp.StatusCode == 200 ?
        bytes(resp.Body).decode_json().as(body,
          has(body.error) ?
            {
              "events": [{"message": "Zabbix API error: " + body.error.encode_json()}],
              "cursor": state.?cursor.orValue({}),
              "api_token": state.api_token,
              "url": state.url
            }
          : has(body.result) && body.result.size() > 0 ?
            body.result.filter(p,
              !has(state.cursor) || !has(state.cursor.seen) || !state.cursor.seen.contains(p.eventid)
            ).as(new_problems,
              {
                "events": new_problems.map(problem, {"message": problem.encode_json()}),
                "cursor": {"seen": body.result.map(p, p.eventid)},
                "api_token": state.api_token,
                "url": state.url
              }
            )
          :
            {
              "events": [],
              "cursor": {"seen": []},
              "api_token": state.api_token,
              "url": state.url
            }
        )
      :
        {
          "events": [{"message": "Zabbix API request failed with HTTP status " + string(resp.StatusCode)}],
          "cursor": state.?cursor.orValue({}),
          "api_token": state.api_token,
          "url": state.url
        }
    )
  )
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
