          request.tracer:
            enabled: true
            filename: ../../logs/cel/http-request-trace-*.ndjson
            maxbackups: 5
          request.url: http://host.tld/web/api/v2.1/threats
          run_as_cel: true
          tags:
            - preserve_original_event
            - forwarded
            - sentinel_one-threat
            - test-policy
      type: httpjson
      use_output: default
output_permissions:
    default:
        _elastic_agent_checks:
            cluster:
                - monitor
        _elastic_agent_monitoring:
            indices: []
        uuid-for-permissions-on-related-indices:
            indices:
                - names:
                    - logs-sentinel_one.threat-ep
                  privileges:
                    - auto_configure
                    - create_doc
secret_references:
    - {}
