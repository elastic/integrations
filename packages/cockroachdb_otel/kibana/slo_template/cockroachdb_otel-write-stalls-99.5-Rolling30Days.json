{
  "attributes": {
    "name": "[CockroachDB OTel] Write stalls 99.5% rolling 30 days",
    "description": "This SLO tracks storage engine health by ensuring that 99.5% of 1-minute time intervals have zero new write stalls (storage_write_stalls delta) over a rolling 30 days. Write stalls block all writes to the store and indicate L0/compaction pressure or disk issues.",
    "indicator": {
      "type": "sli.metric.timeslice",
      "params": {
        "index": "metrics-*",
        "filter": "data_stream.dataset: \"prometheusreceiver.otel\"",
        "metric": {
          "metrics": [
            {
              "name": "A",
              "aggregation": "max",
              "field": "storage_write_stalls"
            },
            {
              "name": "B",
              "aggregation": "min",
              "field": "storage_write_stalls"
            }
          ],
          "equation": "A - B",
          "comparator": "LT",
          "threshold": 1
        },
        "timestampField": "@timestamp"
      }
    },
    "budgetingMethod": "timeslices",
    "timeWindow": {
      "duration": "30d",
      "type": "rolling"
    },
    "objective": {
      "target": 0.995,
      "timesliceTarget": 0.95,
      "timesliceWindow": "1m"
    },
    "tags": [
      "cockroachdb",
      "otel"
    ],
    "groupBy": [
      "resource.attributes.service.instance.id"
    ]
  },
  "artifacts": {
    "dashboards": [
      { "id": "cockroachdb_otel-storage" }
    ]
  },
  "id": "cockroachdb_otel-write-stalls-99.5-Rolling30Days",
  "type": "slo_template"
}
