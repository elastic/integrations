config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  api_key: {{api_key}}
  initial_interval: {{initial_interval}}
  batch_size: {{batch_size}}
{{#if organization_id}}
  organization_id:
{{#each organization_id as |id|}}
    - {{id}}
{{/each}}
{{/if}}
{{#if include_enterprise_level}}
  include_enterprise_level: {{include_enterprise_level}}
{{/if}}
{{#if novel_only}}
  novel_only: {{novel_only}}
{{/if}}
{{#if detection_types}}
  detection_types:
{{#each detection_types as |t|}}
    - {{t}}
{{/each}}
{{/if}}
{{#if source_types}}
  source_types:
{{#each source_types as |t|}}
    - {{t}}
{{/each}}
{{/if}}
{{#if domains}}
  domains:
{{#each domains as |d|}}
    - {{d}}
{{/each}}
{{/if}}
  hash_password: {{hash_password}}
  hash_cookies: {{hash_cookies}}
{{#if hashing_key}}
  hashing_key: {{hashing_key}}
{{/if}}
redact:
  fields:
    - api_key
    - hashing_key
program: |-
  (
    state.?want_more.orValue(false) ?
      state
    :
      state.drop(["offset"]).with(
        {
          "start_time": state.?cursor.last_timestamp.orValue((now - duration(state.initial_interval)).format(time_layout.RFC3339)),
        }
      )
  ).as(state,
    state.with(
      post_request(
        state.url.trim_right("/") + "/identity/detections",
        "application/json",
        {
          "limit": int(state.batch_size),
          ?"offset": (state.?offset.orValue("") != "") ? optional.of(string(state.offset)) : optional.none(),
          ?"organization_id": state.?organization_id[0].hasValue() ? optional.of(state.organization_id) : optional.none(),
          ?"include_enterprise_level": state.?include_enterprise_level.orValue(false) ? optional.of(true) : optional.none(),
          "filter": {
            "created": {"gte": string(state.start_time)},
            ?"novel_only": state.?novel_only.orValue(false) ? optional.of(true) : optional.none(),
            ?"detection_types": state.?detection_types[0].hasValue() ? optional.of(state.detection_types) : optional.none(),
            ?"source_type": state.?source_types[0].hasValue() ? optional.of(state.source_types) : optional.none(),
            ?"domains": state.?domains[0].hasValue() ? optional.of(state.domains) : optional.none(),
          },
        }.encode_json()
      ).with(
        {
          "Header": {
            "Content-Type": ["application/json"],
            "X-RFToken": [state.api_key],
          },
        }
      ).do_request().as(resp, (resp.StatusCode == 200) ?
        resp.Body.decode_json().as(body,
          body.?next_offset.orValue("").as(next_offset,
            (
              (has(body.detections) && body.detections.size() > 0) ?
                string(body.detections.map(e, timestamp(e.created)).max())
              :
                ""
            ).as(page_max,
              (
                (page_max > state.?cursor.max_created.orValue("")) ?
                  page_max
                :
                  state.?cursor.max_created.orValue("")
              ).as(max_created,
                {
                  "events": (has(body.detections) && body.detections.size() > 0) ?
                    body.detections.map(d,
                      {
                        "message": d.as(d,
                          (state.?hash_password.orValue(false) && has(d.password) &&
                          has(d.password.cleartext)) ?
                            d.with({"password": d.password.with({"cleartext": d.password.cleartext.hmac("sha256", bytes(state.?hashing_key.orValue(""))).hex()})})
                          :
                            d
                        ).as(d,
                          (state.?hash_cookies.orValue(false) && has(d.cookies) &&
                          d.cookies.size() > 0) ?
                            d.with(
                              {
                                "cookies": d.cookies.map(c,
                                  has(c.value) ?
                                    c.with({"value": c.value.hmac("sha256", bytes(state.?hashing_key.orValue(""))).hex()})
                                  :
                                    c
                                ),
                              }
                            )
                          :
                            d
                        ).encode_json(),
                      }
                    )
                  :
                    [],
                  "want_more": next_offset != "",
                  ?"offset": (next_offset != "") ? optional.of(next_offset) : optional.none(),
                  "cursor": (next_offset != "") ?
                    {
                      ?"last_timestamp": state.?cursor.last_timestamp,
                      "max_created": max_created,
                    }
                  :
                    {
                      ?"last_timestamp": (max_created != "") ?
                        optional.of(max_created)
                      :
                        state.?cursor.last_timestamp,
                    },
                }
              )
            )
          )
        )
      :
        {
          "events": {
            "error": {
              "code": string(resp.StatusCode),
              "id": string(resp.Status),
              "message": "POST " + state.url.trim_right("/") + "/identity/detections: " + (
                (size(resp.Body) != 0) ?
                  string(resp.Body)
                :
                  string(resp.Status) + " (" + string(resp.StatusCode) + ")"
              ),
            },
          },
          "want_more": false,
        }
      )
    )
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
