config_version: 2
interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.rate_limit.limit: 0.35
resource.rate_limit.burst: 2
resource.url: "{{url}}"
state:
  api_key: "{{api_key}}"
  page_size: {{page_size}}
  initial_interval: "{{initial_interval}}"
  event_types: "{{event_types}}"
redact:
  fields:
    - api_key
program: |-
  state.?cursor.last_timestamp.orValue(
    (now - duration(state.initial_interval)).format(time_layout.RFC3339Nano)
  ).as(start_time,
    state.?cursor.next.window_end.orValue(
      now.format(time_layout.RFC3339Nano)
    ).as(end_time,
      int(state.?cursor.next.page.orValue(1)).as(page,
        state.with(
          request(
            "GET",
            state.url.trim_right("/") + "/teams/audit-logs?" + {
              "startTime": [start_time],
              "endTime": [end_time],
              "page": [string(page)],
              "pageSize": [string(int(state.page_size))],
              ?"eventTypes": (state.?event_types.orValue("") != "") ?
                optional.of([state.event_types])
              :
                optional.none(),
            }.format_query()
          ).with(
            {
              "Header": {
                "Accept": ["application/json"],
                "Authorization": ["Basic " + bytes(state.api_key + ":").base64()],
              },
            }
          ).do_request().as(resp,
            (resp.StatusCode == 200) ?
              resp.Body.decode_json().as(body,
                {
                  "events": body.?events.orValue([]).map(e, {"message": e.encode_json()}),
                  "want_more": body.?pagination.hasNextPage.orValue(false),
                  "cursor": body.?pagination.hasNextPage.orValue(false) ?
                    {
                      "last_timestamp": start_time,
                      "next": {"page": page + 1, "window_end": end_time},
                    }
                  :
                    {"last_timestamp": end_time},
                }
              )
            :
              {
                "events": {
                  "error": {
                    "code": string(resp.StatusCode),
                    "id": string(resp.Status),
                    "message": "GET " + state.url.trim_right("/") + "/teams/audit-logs: " + (
                      (size(resp.Body) != 0) ?
                        string(resp.Body)
                      :
                        string(resp.Status)
                    ),
                  },
                },
                "want_more": false,
              }
          )
        )
      )
    )
  )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
{{#if processors}}
processors:
{{processors}}
{{/if}}
