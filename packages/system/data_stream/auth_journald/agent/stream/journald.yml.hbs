type: journald

# Filter by syslog facilities, replicating the traditional log files
# /var/log/auth.log*, /var/log/secure*
# This is the equivalent to the filter used by rsyslog:
# auth,authpriv.*                 /var/log/auth.log
facilities:
  - 4
  - 10

{{#if condition }}
condition: {{condition}}
{{/if}}

{{#if paths}}
paths:
{{#each paths as |path i|}}
  - {{path}}
{{/each}}
{{/if}}

{{#if include_matches}}
include_matches:
{{#each include_matches as |include_match i|}}
  - '{{include_match}}'
{{/each}}
{{/if}}

{{#if tags}}
tags:
{{#each tags as |tag i|}}
  - {{tag}}
{{/each}}
{{/if}}

{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}

processors:
{{#if processors}}
{{processors}}
{{/if}}
# Workaround to have event.dataset and data_stream.dataset matching the
# log input counterpart
- add_fields:
    target: data_stream
    fields:
      dataset: system.auth
- add_fields:
    target: event
    fields:
      dataset: system.auth