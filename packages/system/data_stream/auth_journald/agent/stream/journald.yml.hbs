type: journald

facilities:
  - 4
  - 10

{{#if condition }}
condition: {{condition}}
{{/if}}

{{#if paths}}
paths:
{{#each paths as |path i|}}
  - {{path}}
{{/each}}
{{/if}}

{{#if include_matches}}
include_matches:
{{#each include_matches as |include_match i|}}
  - '{{include_match}}'
{{/each}}
{{/if}}

{{#if tags}}
tags:
{{#each tags as |tag i|}}
  - {{tag}}
{{/each}}
{{/if}}

{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}

{{#if processors}}
processors:
{{processors}}
{{/if}}
