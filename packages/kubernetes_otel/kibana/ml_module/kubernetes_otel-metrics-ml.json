{
    "id": "kubernetes_otel-metrics-ml",
    "type": "ml-module",
    "migrationVersion": {
        "search": "7.9.3"
    },
    "references": [],
    "attributes": {
        "id": "kubernetes_otel-metrics-ml",
        "title": "Kubernetes workload resources (OpenTelemetry)",
        "description": "Detect anomalies in pod-level resource consumption (memory working set, network throughput) rolled up per workload (Deployment, StatefulSet, DaemonSet) using metrics from the OpenTelemetry kubeletstats receiver. Surfaces slow drifts and time-of-day deviations that fixed-threshold alerts miss.",
        "type": "Container metrics",
        "logo": {
            "icon": "logoKubernetes"
        },
        "defaultIndexPattern": "metrics-kubeletstatsreceiver.otel-*",
        "query": {
            "bool": {
                "filter": [
                    {
                        "exists": {
                            "field": "k8s.pod.memory.working_set"
                        }
                    }
                ],
                "must_not": {
                    "terms": {
                        "_tier": [
                            "data_frozen",
                            "data_cold"
                        ]
                    }
                }
            }
        },
        "jobs": [
            {
                "id": "k8s_workload_memory_anomaly",
                "config": {
                    "groups": [
                        "kubernetes",
                        "otel"
                    ],
                    "description": "Kubernetes: detect workloads (Deployment, StatefulSet, DaemonSet) whose pod memory working set has grown unusually relative to that workload's own history. Catches slow leak trajectories that affect every replica before any individual pod crosses a hard OOM threshold. Per-replica spikes are covered by the threshold-based alert rules.",
                    "analysis_config": {
                        "bucket_span": "15m",
                        "detectors": [
                            {
                                "detector_description": "Anomalous Deployment pod memory working set",
                                "function": "high_mean",
                                "field_name": "k8s.pod.memory.working_set",
                                "by_field_name": "k8s.deployment.name",
                                "partition_field_name": "k8s.namespace.name"
                            },
                            {
                                "detector_description": "Anomalous StatefulSet pod memory working set",
                                "function": "high_mean",
                                "field_name": "k8s.pod.memory.working_set",
                                "by_field_name": "k8s.statefulset.name",
                                "partition_field_name": "k8s.namespace.name"
                            },
                            {
                                "detector_description": "Anomalous DaemonSet pod memory working set",
                                "function": "high_mean",
                                "field_name": "k8s.pod.memory.working_set",
                                "by_field_name": "k8s.daemonset.name",
                                "partition_field_name": "k8s.namespace.name"
                            }
                        ],
                        "influencers": [
                            "k8s.deployment.name",
                            "k8s.statefulset.name",
                            "k8s.daemonset.name",
                            "k8s.namespace.name"
                        ]
                    },
                    "analysis_limits": {
                        "model_memory_limit": "128mb"
                    },
                    "data_description": {
                        "time_field": "@timestamp",
                        "time_format": "epoch_ms"
                    },
                    "model_plot_config": {
                        "enabled": false,
                        "annotations_enabled": true
                    }
                }
            },
            {
                "id": "k8s_workload_network_io_anomaly",
                "config": {
                    "groups": [
                        "kubernetes",
                        "otel"
                    ],
                    "description": "Kubernetes: detect workloads (Deployment, StatefulSet, DaemonSet) whose pod network throughput deviates from that workload's own baseline. Surfaces both unusual spikes (runaway processes, unexpected load) and unusual drops (network partition, idle workload) independently per direction. Time-of-day patterns are learned, so a batch job at high throughput during its window is normal and the same workload at high throughput outside that window is not.",
                    "analysis_config": {
                        "bucket_span": "15m",
                        "detectors": [
                            {
                                "detector_description": "Anomalous Deployment network I/O by direction",
                                "function": "mean",
                                "field_name": "k8s.pod.network.io",
                                "by_field_name": "k8s.deployment.name",
                                "partition_field_name": "direction"
                            },
                            {
                                "detector_description": "Anomalous StatefulSet network I/O by direction",
                                "function": "mean",
                                "field_name": "k8s.pod.network.io",
                                "by_field_name": "k8s.statefulset.name",
                                "partition_field_name": "direction"
                            },
                            {
                                "detector_description": "Anomalous DaemonSet network I/O by direction",
                                "function": "mean",
                                "field_name": "k8s.pod.network.io",
                                "by_field_name": "k8s.daemonset.name",
                                "partition_field_name": "direction"
                            }
                        ],
                        "influencers": [
                            "k8s.deployment.name",
                            "k8s.statefulset.name",
                            "k8s.daemonset.name",
                            "k8s.namespace.name",
                            "direction"
                        ]
                    },
                    "analysis_limits": {
                        "model_memory_limit": "256mb"
                    },
                    "data_description": {
                        "time_field": "@timestamp",
                        "time_format": "epoch_ms"
                    },
                    "model_plot_config": {
                        "enabled": false,
                        "annotations_enabled": true
                    }
                }
            }
        ],
        "datafeeds": [
            {
                "id": "datafeed-k8s_workload_memory_anomaly",
                "job_id": "k8s_workload_memory_anomaly",
                "config": {
                    "job_id": "k8s_workload_memory_anomaly",
                    "indices": [
                        "INDEX_PATTERN_NAME"
                    ],
                    "query": {
                        "bool": {
                            "filter": [
                                {
                                    "exists": {
                                        "field": "k8s.pod.memory.working_set"
                                    }
                                }
                            ],
                            "should": [
                                {
                                    "exists": {
                                        "field": "k8s.deployment.name"
                                    }
                                },
                                {
                                    "exists": {
                                        "field": "k8s.statefulset.name"
                                    }
                                },
                                {
                                    "exists": {
                                        "field": "k8s.daemonset.name"
                                    }
                                }
                            ],
                            "minimum_should_match": 1
                        }
                    }
                }
            },
            {
                "id": "datafeed-k8s_workload_network_io_anomaly",
                "job_id": "k8s_workload_network_io_anomaly",
                "config": {
                    "job_id": "k8s_workload_network_io_anomaly",
                    "indices": [
                        "INDEX_PATTERN_NAME"
                    ],
                    "query": {
                        "bool": {
                            "filter": [
                                {
                                    "exists": {
                                        "field": "k8s.pod.network.io"
                                    }
                                },
                                {
                                    "exists": {
                                        "field": "direction"
                                    }
                                }
                            ],
                            "should": [
                                {
                                    "exists": {
                                        "field": "k8s.deployment.name"
                                    }
                                },
                                {
                                    "exists": {
                                        "field": "k8s.statefulset.name"
                                    }
                                },
                                {
                                    "exists": {
                                        "field": "k8s.daemonset.name"
                                    }
                                }
                            ],
                            "minimum_should_match": 1
                        }
                    }
                }
            }
        ]
    }
}
