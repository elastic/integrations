connectors:
    forward: {}
exporters:
    elasticsearch/componentid-0:
        endpoints:
            - https://elasticsearch:9200
inputs: []
output_permissions:
    default:
        _elastic_agent_checks:
            cluster:
                - monitor
        _elastic_agent_monitoring:
            indices: []
        uuid-for-permissions-on-related-indices:
            indices:
                - names:
                    - logs-*-*
                  privileges:
                    - auto_configure
                    - create_doc
processors:
    transform/componentid-0:
        log_statements:
            - context: log
              statements:
                - set(attributes["data_stream.type"], "logs")
                - set(attributes["data_stream.dataset"], "verifierreceiver")
                - set(attributes["data_stream.namespace"], "ep")
receivers:
    verifier/componentid-0:
        account_type: single-account
        identity_federation_id: test-cc-123
        identity_federation_name: Test Connector
        policies:
            - integrations:
                - package_name: aws
                  package_policy_id: test-pp-789
                  package_title: AWS
                  package_version: "2.17.0"
                  policy_template: cloudtrail
                - package_name: aws
                  package_policy_id: test-pp-789
                  package_title: AWS
                  package_version: "2.17.0"
                  policy_template: guardduty
              policy_id: test-policy-123
              policy_name: Verifier-Policy-Test-Connector-abc12345
        providers:
            aws:
                credentials:
                    external_id: ${SECRET_0}
                    role_arn: arn:aws:iam::123456789012:role/TestRole
        verification_id: test-verify-456
        verification_type: on_demand
secret_references:
    - {}
service:
    pipelines:
        logs:
            exporters:
                - elasticsearch/componentid-0
            receivers:
                - forward
        logs/componentid-0:
            exporters:
                - forward
            processors:
                - transform/componentid-0
            receivers:
                - verifier/componentid-0
